<section id="contact" style="background: var(--bg-dark);">
    <div class="section-header">
        <h2>Get In Touch</h2>
        <p>Submit a request or drop by one of our professional locations.</p>
    </div>
    <div class="contact-grid">
        <form class="glass-panel contact-form">
            <div class="form-group">
                <label>Full Name</label>
                <input type="text" class="form-control" placeholder="Enter your name" required>
            </div>
            <div class="form-group">
                <label>Email Address</label>
                <input type="email" class="form-control" placeholder="Enter your email" required>
            </div>
            <div class="form-group">
                <label>Message / Request Details</label>
                <textarea class="form-control" placeholder="Tell us how we can help you..." required></textarea>
            </div>
            <button type="submit" class="btn-primary">
                <i class="fa-solid fa-paper-plane"></i>
                Send Message
            </button>
        </form>
        <div class="contact-info">
            <div class="glass-panel" style="padding: 30px; display: flex; flex-direction: column; gap: 24px;">
                <div class="info-item">
                    <i class="fa-solid fa-envelope"></i>
                    <div class="info-text">
                        <h5>Business Email</h5>
                        <p>info@ingym.com</p>
                    </div>
                </div>
                <div class="info-item">
                    <i class="fa-solid fa-phone"></i>
                    <div class="info-text">
                        <h5>Hotline Support</h5>
                        <p>+20 102 533 8461</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<footer style="background: var(--bg-deep); padding: 50px 5% 30px; border-top: 1px solid var(--border-color); text-align: center;">
    <p style="color: var(--text-secondary); font-size: 0.9rem;">
        &copy; @DateTime.Now.Year InGym Platform. The complete Gym Management System. All rights reserved.
    </p>
</footer>