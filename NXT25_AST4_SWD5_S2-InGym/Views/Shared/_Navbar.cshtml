<nav class="landing-nav">
    <a asp-controller="Home" asp-action="Index" class="brand-logo">
        <i class="fa-solid fa-circle-nodes"></i>
        InGym
    </a>
    <ul class="nav-links">
        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li><a href="#overview">System</a></li>
        <li><a href="#features">Features</a></li>
        <li><a href="#gallery">Gyms</a></li>
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <li><a asp-controller="Home" asp-action="Dashboard">Dashboard</a></li>
        }
    </ul>
    
    <div style="display: flex; gap: 15px; align-items: center;">
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <span style="color: var(--text-primary); font-weight: 600;">
                Welcome, @User.Identity.Name
            </span>
            <a asp-controller="Account" asp-action="Logout" class="btn-secondary">
                Logout
            </a>
        }
        else
        {
            <a asp-controller="Account" asp-action="Register" class="btn-secondary">
                Register
            </a>
            <a asp-controller="Account" asp-action="Login" class="btn-primary">
                <i class="fa-solid fa-arrow-right-to-bracket"></i>
                Login
            </a>
        }
    </div>
</nav>