@{
    ViewData["Title"] = "Gym Manager Dashboard";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-12">
            <h1 class="mb-4">
                <i class="fas fa-building text-primary"></i> @ViewBag.GymName - Dashboard
            </h1>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card text-white bg-primary">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fas fa-users"></i> Total Coaches
                    </h5>
                    <h2 class="card-text">@ViewBag.Stats.TotalCoaches</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card text-white bg-success">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fas fa-user-friends"></i> Total Members
                    </h5>
                    <h2 class="card-text">@ViewBag.Stats.TotalMembers</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card text-white bg-info">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fas fa-ticket-alt"></i> Active Subscriptions
                    </h5>
                    <h2 class="card-text">@ViewBag.Stats.ActiveSubscriptions</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card text-white bg-warning">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fas fa-sign-in-alt"></i> Total Attendance
                    </h5>
                    <h2 class="card-text">@ViewBag.Stats.TotalAttendance</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row">
        <div class="col-md-12">
            <h4 class="mb-3">Quick Actions</h4>
            <div class="btn-group-vertical w-100" role="group">
                <a href="@Url.Action("Coaches")" class="btn btn-outline-primary text-start">
                    <i class="fas fa-users"></i> Manage Coaches
                </a>
                <a href="@Url.Action("Members")" class="btn btn-outline-success text-start">
                    <i class="fas fa-user-friends"></i> Manage Members
                </a>
                <a href="@Url.Action("Subscriptions")" class="btn btn-outline-info text-start">
                    <i class="fas fa-ticket-alt"></i> View Subscriptions
                </a>
                <a href="@Url.Action("Attendance")" class="btn btn-outline-warning text-start">
                    <i class="fas fa-sign-in-alt"></i> View Attendance
                </a>
            </div>
        </div>
    </div>
</div>

<div class="container mt-5">

    <h2 class="text-danger">
        Welcome Gym Manager 👋
    </h2>

    <hr />

    <div class="row">

        <div class="col-md-4">
            <div class="card shadow">
                <div class="card-body text-center">

                    <h4>Members</h4>

                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow">
                <div class="card-body text-center">

                    <h4>Coaches</h4>

                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow">
                <div class="card-body text-center">

                    <h4>Reports</h4>

                </div>
            </div>
        </div>

    </div>

</div>