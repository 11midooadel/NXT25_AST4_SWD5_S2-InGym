@model Member
@{
    ViewData["Title"] = "Member Details";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>@Model.User.FirstName @Model.User.LastName</h2>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Members")" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to Members
            </a>
        </div>
    </div>

    <div class="row">
        <!-- Personal Info Card -->
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Personal Information</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <h6 class="text-muted">Email</h6>
                        <p>@Model.User.Email</p>
                    </div>
                    <div class="mb-3">
                        <h6 class="text-muted">Gender</h6>
                        <p>@Model.Gender</p>
                    </div>
                    <div class="mb-3">
                        <h6 class="text-muted">Birth Date</h6>
                        <p>@Model.BirthDate.ToString("dd/MM/yyyy")</p>
                    </div>
                    <div class="mb-3">
                        <h6 class="text-muted">Join Date</h6>
                        <p>@Model.JoinDate.ToString("dd/MM/yyyy")</p>
                    </div>
                    <div>
                        <h6 class="text-muted">Status</h6>
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success fs-6">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary fs-6">Inactive</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Physical Info Card -->
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">Physical Information</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <h6 class="text-muted">Height (cm)</h6>
                        <p>@Model.Height</p>
                    </div>
                    <div class="mb-3">
                        <h6 class="text-muted">Weight (kg)</h6>
                        <p>@Model.Weight</p>
                    </div>
                    <div class="mb-3">
                        <h6 class="text-muted">Goals</h6>
                        <p>@Model.Goals</p>
                    </div>
                    <div class="mb-3">
                        <h6 class="text-muted">Physical Restrictions</h6>
                        <p>@(string.IsNullOrEmpty(Model.PhysRestrictions) ? "-" : Model.PhysRestrictions)</p>
                    </div>
                    <div>
                        <h6 class="text-muted">Chronic Diseases</h6>
                        <p>@(string.IsNullOrEmpty(Model.ChronicDiseases) ? "-" : Model.ChronicDiseases)</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Coach Info Card -->
    <div class="row">
        <div class="col-md-12 mb-4">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Assigned Coach</h5>
                </div>
                <div class="card-body">
                    @if (Model.Coach != null)
                    {
                        <div class="row">
                            <div class="col-md-6">
                                <h6 class="text-muted">Coach Name</h6>
                                <p><strong>@Model.Coach.User.FirstName @Model.Coach.User.LastName</strong></p>
                            </div>
                            <div class="col-md-6">
                                <h6 class="text-muted">Email</h6>
                                <p>@Model.Coach.User.Email</p>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <h6 class="text-muted">Speciality</h6>
                                <p>@Model.Coach.Speciality</p>
                            </div>
                            <div class="col-md-6">
                                <h6 class="text-muted">Rating</h6>
                                <p><span class="badge bg-info">@Model.Coach.Rating / 5</span></p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No coach assigned yet</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
