@model Member
@{
    ViewData["Title"] = "Member Details";
	var member = Model as NXT25_AST4_SWD5_S2_InGym.Models.Member;
}

<div class="container mt-4">
	<div class="row">
		<div class="col-md-8 offset-md-2">
			<div class="d-flex justify-content-between align-items-center mb-4">
				<h2>Member Profile</h2>
            <a href="@Url.Action("Members")" class="btn btn-secondary">
					<i class="fas fa-arrow-left"></i> Back
            </a>
        </div>
    </div>

    <div class="row">
        <!-- Personal Info Card -->
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header bg-primary text-white">
					<h5 class="mb-0">@member.User.FirstName @member.User.LastName</h5>
                </div>
                <div class="card-body">
					<div class="row mb-3">
						<div class="col-md-6">
							<p><strong>Email:</strong> @member.User.Email</p>
							<p><strong>Phone:</strong> @(member.User.UserPhones.FirstOrDefault()?.Phone ?? "N/A")</p>
							<p><strong>Gender:</strong> @member.Gender</p>
							<p><strong>Birth Date:</strong> @member.BirthDate.ToString("MMM dd, yyyy")</p>
                    </div>
						<div class="col-md-6">
							<p><strong>Height:</strong> @member.Height cm</p>
							<p><strong>Weight:</strong> @member.Weight kg</p>
							<p><strong>Join Date:</strong> @member.JoinDate.ToString("MMM dd, yyyy")</p>
							<p><strong>Status:</strong> @(member.IsActive ? "<span class='badge bg-success'>Active</span>" : "<span class='badge bg-danger'>Inactive</span>")</p>
						</div>
                    </div>

					<hr />

					<div class="row mb-3">
						<div class="col-md-12">
							<p><strong>Goals:</strong> @member.Goals</p>
							<p><strong>Physical Restrictions:</strong> @member.PhysRestrictions</p>
							<p><strong>Chronic Diseases:</strong> @member.ChronicDiseases</p>
                    </div>
                    <div class="mb-3">
                        <h6 class="text-muted">Join Date</h6>
                        <p>@Model.JoinDate.ToString("dd/MM/yyyy")</p>
                    </div>

					<hr />

					<div class="row">
						<div class="col-md-4">
							<div class="card bg-light">
								<div class="card-body">
									<h6 class="card-title">Assigned Coach</h6>
									<p class="card-text">
										@if (member.Coach != null)
                        {
											<strong>@member.Coach.User.FirstName @member.Coach.User.LastName</strong><br />
											<small class="text-muted">@member.Coach.Speciality</small>
                        }
                        else
                        {
											<span class="text-muted">No coach assigned</span>
                        }
									</p>
                    </div>
                </div>
            </div>
						<div class="col-md-4">
							<div class="card bg-light">
                <div class="card-body">
									<h6 class="card-title">Attendance</h6>
									<p class="card-text">
										<strong>@ViewBag.MemberAttendanceCount</strong> check-ins
									</p>
                    </div>
                    <div class="mb-3">
                        <h6 class="text-muted">Weight (kg)</h6>
                        <p>@Model.Weight</p>
                    </div>
                    <div class="mb-3">
                        <h6 class="text-muted">Goals</h6>
                        <p>@Model.Goals</p>
                    </div>
						<div class="col-md-4">
							<div class="card bg-light">
                <div class="card-body">
									<h6 class="card-title">Active Subscriptions</h6>
									<p class="card-text">
										<strong>@ViewBag.MemberSubscriptionsCount</strong>
									</p>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <h6 class="text-muted">Speciality</h6>
                                <p>@Model.Coach.Speciality</p>
                            </div>
                            <div class="col-md-6">
                                <h6 class="text-muted">Rating</h6>
                                <p><span class="badge bg-info">@Model.Coach.Rating / 5</span></p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No coach assigned yet</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
