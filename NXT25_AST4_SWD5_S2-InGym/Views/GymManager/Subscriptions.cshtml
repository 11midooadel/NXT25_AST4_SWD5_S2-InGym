@{
	ViewData["Title"] = "Subscriptions";
	var subscriptions = Model as List<NXT25_AST4_SWD5_S2_InGym.Models.MemberGymSub>;
}

<div class="container mt-4">
	<div class="row">
		<div class="col-md-12">
			<div class="d-flex justify-content-between align-items-center mb-4">
				<h2>Active Subscriptions</h2>
				<a href="@Url.Action("Dashboard")" class="btn btn-secondary">
					<i class="fas fa-arrow-left"></i> Back
				</a>
			</div>

			@if (subscriptions.Any())
			{
				<div class="table-responsive">
					<table class="table table-hover table-striped">
						<thead class="table-dark">
							<tr>
								<th>Member Name</th>
								<th>Subscription Type</th>
								<th>Price</th>
								<th>Start Date</th>
								<th>End Date</th>
								<th>Status</th>
							</tr>
						</thead>
						<tbody>
							@foreach (var sub in subscriptions)
							{
								<tr>
									<td>@sub.Member.User.FirstName @sub.Member.User.LastName</td>
									<td><span class="badge bg-info">@sub.GymSub.DurationMonths month(s)</span></td>
									<td>$@sub.GymSub.Price</td>
									<td>@sub.StartDate.ToString("MMM dd, yyyy")</td>
									<td>@sub.EndDate.ToString("MMM dd, yyyy")</td>
									<td>
										@if (sub.IsActive)
										{
											<span class="badge bg-success">Active</span>
										}
										else
										{
											<span class="badge bg-danger">Expired</span>
										}
									</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			}
			else
			{
				<div class="alert alert-info" role="alert">
					<i class="fas fa-info-circle"></i> No active subscriptions.
				</div>
			}
		</div>
	</div>
</div>
