@{
    ViewData["Title"] = "Add Coach to Gym";
    var coaches = (dynamic)ViewBag.Coaches;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h2 class="mb-4">Add Coach to Gym</h2>

            <form method="post" asp-action="AddCoach" class="needs-validation">
                @Html.AntiForgeryToken()

                <div class="card">
                    <div class="card-body">
                        <div class="mb-3">
                            <label for="coachId" class="form-label"><strong>Select Coach</strong></label>
                            <select name="coachId" class="form-select" required>
                                <option value="">-- Choose a Coach --</option>
                                @foreach (var coach in coaches)
                                {
                                    <option value="@coach.Value">@coach.Text</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-check-circle"></i> Add Coach
                    </button>
                    <a href="@Url.Action("Coaches")" class="btn btn-secondary btn-lg">
                        <i class="bi bi-x-circle"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
