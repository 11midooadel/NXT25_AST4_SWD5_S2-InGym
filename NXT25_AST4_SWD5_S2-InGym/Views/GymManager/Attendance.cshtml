@{
	ViewData["Title"] = "Attendance Records";
	var attendances = Model as List<NXT25_AST4_SWD5_S2_InGym.Models.Attendance>;
}

<div class="container mt-4">
	<div class="row">
		<div class="col-md-12">
			<div class="d-flex justify-content-between align-items-center mb-4">
				<h2>Attendance Records</h2>
				<a href="@Url.Action("Dashboard")" class="btn btn-secondary">
					<i class="fas fa-arrow-left"></i> Back
				</a>
			</div>

			@if (attendances.Any())
			{
				<div class="table-responsive">
					<table class="table table-hover table-striped">
						<thead class="table-dark">
							<tr>
								<th>Member Name</th>
								<th>Check-In Time</th>
								<th>Check-Out Time</th>
								<th>Duration</th>
							</tr>
						</thead>
						<tbody>
							@foreach (var record in attendances)
							{
								<tr>
									<td>@record.Member.User.FirstName @record.Member.User.LastName</td>
									<td>@record.CheckInTime.ToString("MMM dd, yyyy HH:mm")</td>
									<td>
										@if (record.CheckOutTime.HasValue)
										{
											@record.CheckOutTime.Value.ToString("HH:mm")
										}
										else
										{
											<span class="badge bg-warning">Still checked in</span>
										}
									</td>
									<td>
										@if (record.CheckOutTime.HasValue)
										{
											var duration = record.CheckOutTime.Value - record.CheckInTime;
											@($"{(int)duration.TotalHours}h {duration.Minutes}m")
										}
										else
										{
											<span class="text-muted">-</span>
										}
									</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			}
			else
			{
				<div class="alert alert-info" role="alert">
					<i class="fas fa-info-circle"></i> No attendance records yet.
				</div>
			}
		</div>
	</div>
</div>
