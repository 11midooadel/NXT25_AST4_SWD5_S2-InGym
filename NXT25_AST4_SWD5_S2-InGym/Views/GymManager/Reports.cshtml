@{
    ViewData["Title"] = "Gym Reports";
    var attendanceData = (dynamic)ViewBag.AttendanceData;
    var coachPerformance = (dynamic)ViewBag.CoachPerformance;
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>Gym Reports & Analytics</h2>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Dashboard")" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    <!-- Attendance Report Card -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Attendance Report (Last 30 Days)</h5>
                </div>
                <div class="card-body">
                    @if (attendanceData != null && attendanceData.Count > 0)
                    {
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Check-ins</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var data in attendanceData)
                                    {
                                        <tr>
                                            <td>@data.Date.ToString("dd/MM/yyyy")</td>
                                            <td>@data.Count</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No attendance data available.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Coach Performance Card -->
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Coach Performance</h5>
                </div>
                <div class="card-body">
                    @if (coachPerformance != null && coachPerformance.Count > 0)
                    {
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>Coach Name</th>
                                        <th>Members Assigned</th>
                                        <th>Rating</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var coach in coachPerformance)
                                    {
                                        <tr>
                                            <td><strong>@coach.CoachName</strong></td>
                                            <td>@coach.MemberCount</td>
                                            <td><span class="badge bg-info">@coach.Rating / 5</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No coach performance data available.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
