@model List<Member>
@{
    ViewData["Title"] = "Manage Members";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>Gym Members</h2>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Dashboard")" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    @if (Model?.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Gender</th>
                        <th>Coach</th>
                        <th>Status</th>
                        <th>Join Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var member in Model)
                    {
                        <tr>
                            <td><strong>@member.User.FirstName @member.User.LastName</strong></td>
                            <td>@member.User.Email</td>
                            <td>@member.Gender</td>
                            <td>
                                @if (member.Coach != null)
                                {
                                    <span>@member.Coach.User.FirstName @member.Coach.User.LastName</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (member.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>@member.JoinDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                <a href="@Url.Action("MemberDetails", new { memberId = member.MemberID })" class="btn btn-sm btn-info">
                                    <i class="bi bi-eye"></i> View
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            <i class="bi bi-info-circle"></i> No members in this gym yet.
        </div>
    }
</div>
