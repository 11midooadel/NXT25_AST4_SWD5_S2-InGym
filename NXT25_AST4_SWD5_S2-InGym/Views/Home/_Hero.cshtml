<section class="hero-section" id="home">
    <div class="hero-grid">
        <div class="hero-content">
            <h1 class="hero-title">A <span>Gym Management System</span> at your service</h1>
            <p class="hero-subtitle">
                InGym is a state-of-the-art gym management and personal training platform.
                We bridge the gap between coaches and trainees by tracking InBody scans,
                structuring custom diet & workout routines, and offering role-based access.
            </p>
            <div class="hero-buttons">
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Home" asp-action="Dashboard" class="btn-primary">
                        Go To Dashboard
                        <i class="fa-solid fa-chevron-right"></i>
                    </a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Register" class="btn-primary">
                        Get Started
                        <i class="fa-solid fa-chevron-right"></i>
                    </a>
                }
                <a href="#overview" class="btn-secondary">
                    Learn More
                    <i class="fa-solid fa-circle-info"></i>
                </a>
            </div>
            <div class="hero-stats">
                <div class="stat-item">
                    <h3>10k+</h3>
                    <p>Active Trainees</p>
                </div>
                <div class="stat-item">
                    <h3>50+</h3>
                    <p>Certified Coaches</p>
                </div>
                <div class="stat-item">
                    <h3>15</h3>
                    <p>Gyms</p>
                </div>
            </div>
        </div>
        <div class="hero-visual">
            <div class="glass-panel" style="padding: 30px; border-radius: var(--border-radius-lg); position: relative; overflow: hidden;">
                <div style="width: 100%; height: 350px; border-radius: var(--border-radius-md); overflow: hidden; margin-bottom: 20px; border: 1px solid var(--border-color);">
                    <img src="https://images.unsplash.com/photo-1540575467063-178a50c2df87?q=80&w=600&auto=format&fit=cover" alt="Premium Fitness Facility" style="width: 100%; height: 100%; object-fit: cover;">
                </div>
                <h3 style="margin-bottom: 8px;"><i class="fa-solid fa-heart-pulse" style="color: var(--accent-brand); margin-right: 8px;"></i> Live Health Analytics</h3>
                <p style="color: var(--text-secondary); font-size: 0.9rem;">
                    Real-time biometric monitoring paired with progress line-charts allows trainers to pivot plans dynamically.
                </p>
            </div>
        </div>
    </div>
</section>