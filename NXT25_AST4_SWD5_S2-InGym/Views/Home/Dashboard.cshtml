@model NXT25_AST4_SWD5_S2_InGym.ViewModels.DashboardViewModel

@{
	ViewData["Title"] = "Dashboard";
}

<div class="container-fluid mt-4">
	<h2 class="mb-4">Welcome, @Model.FullName! 👋</h2>

	<!-- Quick Stats -->
	<div class="row mb-4">
		<div class="col-md-3 mb-3">
			<div class="card text-white bg-primary">
				<div class="card-body text-center">
					<h5 class="card-title">My Gym</h5>
					<h6 class="card-text">@Model.GymName</h6>
				</div>
			</div>
		</div>
		<div class="col-md-3 mb-3">
			<div class="card text-white bg-success">
				<div class="card-body text-center">
					<h5 class="card-title">My Coach</h5>
					<h6 class="card-text">@Model.CoachName</h6>
				</div>
			</div>
		</div>
		<div class="col-md-3 mb-3">
			<div class="card text-white bg-info">
				<div class="card-body text-center">
					<h5 class="card-title">Subscription Status</h5>
					@if (Model.SubscriptionActive)
					{
						<h6 class="card-text">@Model.DaysRemaining days left</h6>
					}
					else
					{
						<h6 class="card-text">Inactive</h6>
					}
				</div>
			</div>
		</div>
		<div class="col-md-3 mb-3">
			<div class="card text-white bg-warning">
				<div class="card-body text-center">
					<h5 class="card-title">Today Check-In</h5>
					@if (Model.CheckedInToday)
					{
						<h6 class="card-text">@Model.TodayCheckIn?.ToString("HH:mm")</h6>
					}
					else
					{
						<h6 class="card-text">Not checked in</h6>
					}
				</div>
			</div>
		</div>
	</div>

	<!-- Main Content -->
	<div class="row">
		<!-- Personal Info -->
		<div class="col-lg-4 mb-4">
			<div class="card h-100">
				<div class="card-header bg-primary text-white">
					<i class="fas fa-user"></i> Personal Information
				</div>
				<div class="card-body">
					<p><strong>Email:</strong> @Model.Email</p>
					<p><strong>Gender:</strong> @Model.Gender</p>
					<p><strong>Height:</strong> @Model.Height cm</p>
					<p><strong>Weight:</strong> @Model.Weight kg</p>
					<p><strong>BMI:</strong> @{
						double height = Model.Height / 100;
						double bmi = Model.Weight / (height * height);
						@bmi.ToString("F2")
					}</p>
					<p><strong>Goals:</strong> @Model.Goals</p>
					<p><strong>Join Date:</strong> @Model.JoinDate.ToString("MMM dd, yyyy")</p>
					<p>
						<strong>Status:</strong>
						@if (Model.IsActive)
						{
							<span class="badge bg-success">Active</span>
						}
						else
						{
							<span class="badge bg-danger">Inactive</span>
						}
					</p>
				</div>
			</div>
		</div>

		<!-- Gym & Subscription -->
		<div class="col-lg-4 mb-4">
			<div class="card h-100">
				<div class="card-header bg-success text-white">
					<i class="fas fa-building"></i> Gym & Subscription
				</div>
				<div class="card-body">
					<p><strong>Gym Name:</strong> @Model.GymName</p>
					<p><strong>Location:</strong> @Model.GymLocation</p>
					@if (Model.SubscriptionActive)
					{
						<hr />
						<p><strong>Subscription Price:</strong> $@Model.SubscriptionPrice</p>
						<p><strong>Duration:</strong> @Model.DurationMonths months</p>
						<p><strong>Start Date:</strong> @Model.StartDate.ToString("MMM dd, yyyy")</p>
						<p><strong>End Date:</strong> @Model.EndDate.ToString("MMM dd, yyyy")</p>
						<p><strong>Days Remaining:</strong> <span class="badge bg-warning">@Model.DaysRemaining days</span></p>
					}
					else
					{
						<div class="alert alert-warning" role="alert">
							No active subscription. <a asp-action="ChooseSubscription" asp-controller="Subscription">Get one now</a>
						</div>
					}
				</div>
			</div>
		</div>

		<!-- Coach Info -->
		<div class="col-lg-4 mb-4">
			<div class="card h-100">
				<div class="card-header bg-info text-white">
					<i class="fas fa-user-tie"></i> My Coach
				</div>
				<div class="card-body">
					<p><strong>Name:</strong> @Model.CoachName</p>
					@if (Model.CoachName != "No Coach Selected")
					{
						<p><strong>Email:</strong> @Model.CoachEmail</p>
						<p><strong>Speciality:</strong> @Model.CoachSpeciality</p>
						<p><strong>Rating:</strong> ★ @Model.CoachRating</p>
					}
					else
					{
						<div class="alert alert-info" role="alert">
							No coach assigned yet. <a asp-action="ChooseGymCoach" asp-controller="Coach">Choose one</a>
						</div>
					}
				</div>
			</div>
		</div>
	</div>

	<!-- Workout & Diet Plans -->
	<div class="row mt-4">
		<div class="col-lg-6 mb-4">
			<div class="card h-100">
				<div class="card-header bg-danger text-white">
					<i class="fas fa-dumbbell"></i> Workout Plans
				</div>
				<div class="card-body">
					<p>View and track your workout plans created by your coach.</p>
					<a href="@Url.Action("Index", "Workout")" class="btn btn-primary btn-sm">
						<i class="fas fa-eye"></i> View Workout Plans
					</a>
				</div>
			</div>
		</div>

		<div class="col-lg-6 mb-4">
			<div class="card h-100">
				<div class="card-header bg-warning text-dark">
					<i class="fas fa-utensils"></i> Diet Plans
				</div>
				<div class="card-body">
					<p>Check your nutrition guidance and diet targets.</p>
					<a href="@Url.Action("MyDietPlans", "DietPlan")" class="btn btn-primary btn-sm">
						<i class="fas fa-eye"></i> View Diet Plans
					</a>
				</div>
			</div>
		</div>
	</div>

	<!-- Health & Attendance -->
	<div class="row mt-4">
		<div class="col-lg-6 mb-4">
			<div class="card h-100">
				<div class="card-header bg-success text-white">
					<i class="fas fa-heartbeat"></i> Health Metrics
				</div>
				<div class="card-body">
					<p>Track your weight and body fat progress over time.</p>
					<a href="@Url.Action("MyMetrics", "HealthMetric")" class="btn btn-primary btn-sm">
						<i class="fas fa-chart-line"></i> View Health Metrics
					</a>
				</div>
			</div>
		</div>

		<div class="col-lg-6 mb-4">
			<div class="card h-100">
				<div class="card-header bg-info text-white">
					<i class="fas fa-calendar-check"></i> Attendance
				</div>
				<div class="card-body">
					@if (Model.CheckedInToday)
					{
						<p><strong>Checked in today at:</strong> @Model.TodayCheckIn?.ToString("HH:mm")</p>
						@if (Model.TodayCheckOut.HasValue)
						{
							<p><strong>Checked out at:</strong> @Model.TodayCheckOut?.ToString("HH:mm")</p>
						}
					}
					else
					{
						<p>You haven't checked in today. Visit the gym to check in.</p>
					}
					<a href="@Url.Action("Index", "Attendance")" class="btn btn-primary btn-sm mt-2">
						<i class="fas fa-history"></i> Check-In/Out
					</a>
				</div>
			</div>
		</div>
	</div>

	<!-- Private Trainer (if applicable) -->
	@if (Model.HasPrivateSubscription)
	{
		<div class="row mt-4">
			<div class="col-lg-12">
				<div class="card">
					<div class="card-header bg-secondary text-white">
						<i class="fas fa-star"></i> Private Training
					</div>
					<div class="card-body">
						<div class="row">
							<div class="col-md-6">
								<p><strong>Coach:</strong> @Model.PrivateCoachName</p>
								<p><strong>Email:</strong> @Model.PrivateCoachEmail</p>
								<p><strong>Speciality:</strong> @Model.PrivateCoachSpeciality</p>
								<p><strong>Rating:</strong> ★ @Model.PrivateCoachRating</p>
							</div>
							<div class="col-md-6">
								<p><strong>Package Price:</strong> $@Model.PrivatePackagePrice</p>
								<p><strong>Sessions:</strong> @Model.PrivateSessionCount</p>
								<p><strong>End Date:</strong> @Model.PrivateEndDate.ToString("MMM dd, yyyy")</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	}

	<!-- Quick Actions -->
	<div class="row mt-4 mb-4">
		<div class="col-lg-12">
			<h5 class="mb-3">Quick Actions</h5>
			<div class="d-flex gap-2 flex-wrap">
				<a href="@Url.Action("Index", "Attendance")" class="btn btn-primary">
					<i class="fas fa-sign-in-alt"></i> Check In/Out
				</a>
				<a href="@Url.Action("MyMetrics", "HealthMetric")" class="btn btn-success">
					<i class="fas fa-chart-line"></i> Health Metrics
				</a>
				<a href="@Url.Action("MyDietPlans", "DietPlan")" class="btn btn-warning">
					<i class="fas fa-utensils"></i> Diet Plans
				</a>
				<a href="@Url.Action("Index", "Workout")" class="btn btn-danger">
					<i class="fas fa-dumbbell"></i> Workouts
				</a>
				@if (!Model.SubscriptionActive)
				{
					<a href="@Url.Action("ChooseSubscription", "Subscription")" class="btn btn-outline-primary">
						<i class="fas fa-ticket-alt"></i> Get Subscription
					</a>
				}
			</div>
		</div>
	</div>
</div>
