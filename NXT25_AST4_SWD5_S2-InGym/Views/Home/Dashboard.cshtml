@model NXT25_AST4_SWD5_S2_InGym.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-5">

    <h2 class="text-center mb-4 text-danger">
        Welcome, @Model.FullName 👋
    </h2>

    <div class="row">

        <!-- Personal -->
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="card shadow h-100">
                <div class="card-header bg-danger text-white">
                    Personal Information
                </div>

                <div class="card-body">

                    <p><strong>Name:</strong> @Model.FullName</p>

                    <p><strong>Email:</strong> @Model.Email</p>

                    <p><strong>Gender:</strong> @Model.Gender</p>

                    <p><strong>Join Date:</strong> @Model.JoinDate.ToString("dd/MM/yyyy")</p>

                    <p>
                        <strong>Status:</strong>

                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Inactive</span>
                        }

                    </p>

                </div>

            </div>
        </div>

        <!-- Fitness -->
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="card shadow h-100">

                <div class="card-header bg-dark text-white">
                    Fitness Information
                </div>

                <div class="card-body">

                    <p><strong>Height:</strong> @Model.Height cm</p>

                    <p><strong>Weight:</strong> @Model.Weight kg</p>

                    <p><strong>Goal:</strong></p>

                    <div class="alert alert-light border">
                        @Model.Goals
                    </div>

                </div>

            </div>
        </div>

        <!-- Gym -->
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="card shadow h-100">

                <div class="card-header bg-primary text-white">
                    Gym Information
                </div>

                <div class="card-body">

                    <p><strong>Gym:</strong> @Model.GymName</p>

                    <p><strong>Location:</strong> @Model.GymLocation</p>

                </div>

            </div>
        </div>

        <!-- Gym Subscription -->
        <div class="col-lg-6 col-md-6 mb-4">
            <div class="card shadow h-100">

                <div class="card-header bg-success text-white">
                    Gym Subscription
                </div>

                <div class="card-body">

                    @if (Model.SubscriptionActive)
                    {
                        <p><strong>Price:</strong> @Model.SubscriptionPrice EGP</p>

                        <p><strong>Duration:</strong> @Model.DurationMonths Month(s)</p>

                        <p><strong>Start:</strong> @Model.StartDate.ToString("dd/MM/yyyy")</p>

                        <p><strong>End:</strong> @Model.EndDate.ToString("dd/MM/yyyy")</p>

                        <p><strong>Remaining:</strong> @Model.DaysRemaining Day(s)</p>

                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">
                            No Active Subscription
                        </span>
                    }

                </div>

            </div>
        </div>

        <!-- Gym Coach -->
        <div class="col-lg-6 col-md-6 mb-4">
            <div class="card shadow h-100">

                <div class="card-header bg-warning text-dark">
                    My Gym Coach
                </div>

                <div class="card-body">

                    <p><strong>Name:</strong> @Model.CoachName</p>

                    <p><strong>Email:</strong> @Model.CoachEmail</p>

                    <p><strong>Speciality:</strong> @Model.CoachSpeciality</p>

                    <p><strong>Rating:</strong> ⭐ @Model.CoachRating</p>

                </div>

            </div>
        </div>

        <!-- Private Trainer -->
        <div class="col-lg-12 mb-4">

            <div class="card shadow">

                <div class="card-header bg-info text-white">
                    Private Trainer
                </div>

                <div class="card-body">

                    @if (Model.HasPrivateSubscription)
                    {
                        <div class="row">

                            <div class="col-md-6">

                                <p><strong>Name:</strong> @Model.PrivateCoachName</p>

                                <p><strong>Email:</strong> @Model.PrivateCoachEmail</p>

                                <p><strong>Speciality:</strong> @Model.PrivateCoachSpeciality</p>

                                <p><strong>Rating:</strong> ⭐ @Model.PrivateCoachRating</p>

                            </div>

                            <div class="col-md-6">

                                <p><strong>Sessions:</strong> @Model.PrivateSessionCount</p>

                                <p><strong>Package Price:</strong> @Model.PrivatePackagePrice EGP</p>

                                <p><strong>Expire Date:</strong> @Model.PrivateEndDate.ToString("dd/MM/yyyy")</p>

                                <span class="badge bg-success">
                                    Active
                                </span>

                            </div>

                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning mb-0">

                            <h5>No Private Trainer Subscription</h5>

                            <p>
                                You don't have any private trainer yet.
                            </p>

                            <a asp-controller="PrivateTrainer"
                               asp-action="ChooseCoach"
                               class="btn btn-warning">

                                Subscribe Now

                            </a>

                        </div>
                    }

                </div>

            </div>

        </div>

    </div>

    <hr />

    <div class="text-center">

        <a asp-controller="PrivateTrainer"
           asp-action="ChooseCoach"
           class="btn btn-warning btn-lg me-2">

            Choose Private Trainer

        </a>

        <a asp-controller="Attendance"
           asp-action="Index"
           class="btn btn-outline-primary btn-lg">

            Attendance

        </a>

    </div>

</div>