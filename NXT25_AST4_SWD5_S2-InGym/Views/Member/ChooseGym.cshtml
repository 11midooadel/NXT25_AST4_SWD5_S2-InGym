@model IEnumerable<NXT25_AST4_SWD5_S2_InGym.Models.Gym>

@{
    ViewData["Title"] = "Choose Gym";
}

<div class="container mt-5">

    <h2 class="text-center text-danger mb-5">
        Choose Your Gym
    </h2>

    <div class="row">

        @foreach (var gym in Model)
        {
            <div class="col-md-4 mb-4">

                <div class="card shadow h-100">

                    <div class="card-body">

                        <h4 class="text-danger">
                            @gym.GymName
                        </h4>

                        <hr />

                        <p>
                            <strong>Registration Date:</strong><br />
                            @gym.RegistrationDate.ToString("dd/MM/yyyy")
                        </p>

                        <p>
                            <strong>Locations:</strong>
                        </p>

                        <ul>
                            @foreach (var location in gym.GymLocations)
                            {
                                <li>@location.Location</li>
                            }
                        </ul>

                    </div>

                    <div class="card-footer text-center">

                        <a asp-action="JoinGym"
                           asp-route-id="@gym.GymID"
                           class="btn btn-danger">
                            Join Gym
                        </a>

                    </div>

                </div>

            </div>
        }

    </div>

</div>