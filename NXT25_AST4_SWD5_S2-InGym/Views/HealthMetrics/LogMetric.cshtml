@model HealthMetricLog
@{
    ViewData["Title"] = "Log Health Metric";
    var memberId = (int)ViewBag.MemberID;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h2 class="mb-4">Log Health Metric</h2>

            <form method="post" asp-action="LogMetric" asp-controller="HealthMetrics" class="needs-validation">
                @Html.AntiForgeryToken()
                <input type="hidden" name="memberId" value="@memberId" />

                <div class="card">
                    <div class="card-body">
                        <!-- Weight -->
                        <div class="mb-3">
                            <label asp-for="Weight" class="form-label"><strong>Weight (kg)</strong></label>
                            <input asp-for="Weight" type="number" step="0.1" class="form-control" placeholder="75.5" />
                            <span asp-validation-for="Weight" class="text-danger"></span>
                        </div>

                        <!-- Body Fat -->
                        <div class="mb-3">
                            <label asp-for="BodyFat" class="form-label"><strong>Body Fat (%)</strong></label>
                            <input asp-for="BodyFat" type="number" step="0.1" class="form-control" placeholder="20.5" />
                            <span asp-validation-for="BodyFat" class="text-danger"></span>
                        </div>

                        <!-- BMI -->
                        <div class="mb-3">
                            <label asp-for="BMI" class="form-label"><strong>BMI</strong></label>
                            <input asp-for="BMI" type="number" step="0.1" class="form-control" placeholder="24.5" />
                            <small class="form-text text-muted">BMI = Weight (kg) / (Height (m))²</small>
                            <span asp-validation-for="BMI" class="text-danger"></span>
                        </div>

                        <!-- Muscle Mass -->
                        <div class="mb-3">
                            <label asp-for="MuscleMass" class="form-label"><strong>Muscle Mass (kg)</strong></label>
                            <input asp-for="MuscleMass" type="number" step="0.1" class="form-control" placeholder="60.0" />
                            <span asp-validation-for="MuscleMass" class="text-danger"></span>
                        </div>

                        <!-- Notes -->
                        <div class="mb-3">
                            <label asp-for="Notes" class="form-label"><strong>Notes</strong></label>
                            <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Add any notes about this measurement..."></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <!-- Buttons -->
                <div class="mt-4">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-check-circle"></i> Log Metric
                    </button>
                    <a href="@Url.Action("ViewMemberMetrics", new { memberId })" class="btn btn-secondary btn-lg">
                        <i class="bi bi-x-circle"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
