@model List<HealthMetricLog>
@{
    ViewData["Title"] = "Member Health Metrics";
    var memberId = (int)ViewBag.MemberID;
    var memberName = (string)ViewBag.MemberName;
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>Health Metrics - @memberName</h2>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("LogMetric", new { memberId })" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Log Metric
            </a>
            <a href="@Url.Action("ManageMember", "Coach", new { id = memberId })" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    @if (Model?.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Date</th>
                        <th>Weight (kg)</th>
                        <th>Body Fat (%)</th>
                        <th>BMI</th>
                        <th>Muscle Mass (kg)</th>
                        <th>Notes</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var metric in Model)
                    {
                        <tr>
                            <td><strong>@metric.LogDate.ToString("dd/MM/yyyy")</strong></td>
                            <td>@metric.Weight</td>
                            <td>@metric.BodyFat</td>
                            <td>@metric.BMI</td>
                            <td>@metric.MuscleMass</td>
                            <td>@metric.Notes</td>
                            <td>
                                <a href="@Url.Action("EditMetric", new { id = metric.MetricID })" class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <form method="post" action="@Url.Action("DeleteMetric")" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@metric.MetricID" />
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?')">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            <i class="bi bi-info-circle"></i> No health metrics logged yet.
            <a href="@Url.Action("LogMetric", new { memberId })" class="alert-link">Log the first metric</a>
        </div>
    }
</div>
