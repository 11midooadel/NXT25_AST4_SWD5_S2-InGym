@model List<HealthMetricLog>
@{
    ViewData["Title"] = "My Health Metrics";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>My Health Metrics</h2>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Dashboard", "Home")" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>

    @if (Model?.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Date</th>
                        <th>Weight (kg)</th>
                        <th>Body Fat (%)</th>
                        <th>BMI</th>
                        <th>Muscle Mass (kg)</th>
                        <th>Notes</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var metric in Model)
                    {
                        <tr>
                            <td><strong>@metric.LogDate.ToString("dd/MM/yyyy")</strong></td>
                            <td>@metric.Weight</td>
                            <td>@metric.BodyFat</td>
                            <td>@metric.BMI</td>
                            <td>@metric.MuscleMass</td>
                            <td>@metric.Notes</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            <i class="bi bi-info-circle"></i> Your coach hasn't logged any health metrics yet.
        </div>
    }
</div>
