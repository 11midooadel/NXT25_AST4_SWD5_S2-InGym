@model List<NXT25_AST4_SWD5_S2_InGym.ViewModels.Coach.HealthMetricViewModel>

@{
	ViewData["Title"] = "Member Health Metrics";
}

<div class="container mt-4">
	<div class="row">
		<div class="col-md-10 offset-md-1">
			<div class="d-flex justify-content-between align-items-center mb-4">
				<div>
					<h2>Health Metrics History</h2>
					@if (Model.Any())
					{
						<p class="text-muted">Member: <strong>@Model.First().MemberName</strong></p>
					}
				</div>
				<a href="javascript:history.back()" class="btn btn-secondary">
					<i class="fas fa-arrow-left"></i> Back
				</a>
			</div>

			@if (Model.Any())
			{
				<div class="table-responsive">
					<table class="table table-hover table-striped">
						<thead class="table-dark">
							<tr>
								<th>Date</th>
								<th>Weight</th>
								<th>Body Fat %</th>
								<th>Action</th>
							</tr>
						</thead>
						<tbody>
							@foreach (var metric in Model)
							{
								<tr>
									<td>@metric.FormattedDate</td>
									<td>@metric.FormattedWeight</td>
									<td>@metric.FormattedBodyFatPercentage</td>
									<td>
										<form asp-action="DeleteMetric" method="post" style="display:inline;" 
											  onsubmit="return confirm('Are you sure you want to delete this metric?');">
											<input type="hidden" name="metricId" value="@metric.MetricID" />
											<input type="hidden" name="memberId" value="@(Model.First().MemberName == metric.MemberName ? "" : metric.MetricID)" />
											<button type="submit" class="btn btn-sm btn-danger">
												<i class="fas fa-trash"></i> Delete
											</button>
										</form>
									</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			}
			else
			{
				<div class="alert alert-info" role="alert">
					<i class="fas fa-info-circle"></i> No health metrics logged yet.
				</div>
			}
		</div>
	</div>
</div>
