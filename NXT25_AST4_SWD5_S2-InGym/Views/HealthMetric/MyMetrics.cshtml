@model List<NXT25_AST4_SWD5_S2_InGym.ViewModels.Coach.HealthMetricViewModel>

@{
	ViewData["Title"] = "My Health Metrics";
}

<div class="container mt-4">
	<div class="row">
		<div class="col-md-10 offset-md-1">
			<div class="d-flex justify-content-between align-items-center mb-4">
				<div>
					<h2>My Health Metrics</h2>
					<p class="text-muted">Track your fitness progress</p>
				</div>
				<a href="@Url.Action("Dashboard", "Home")" class="btn btn-secondary">
					<i class="fas fa-arrow-left"></i> Back
				</a>
			</div>

			@if (Model.Any())
			{
				<div class="row mb-4">
					@{
						var latestMetric = Model.First();
					}
					<div class="col-md-4">
						<div class="card bg-light">
							<div class="card-body">
								<h6 class="card-title text-muted">Latest Weight</h6>
								<h3 class="card-text">@latestMetric.FormattedWeight</h3>
								<small class="text-muted">@latestMetric.FormattedDate</small>
							</div>
						</div>
					</div>
					<div class="col-md-4">
						<div class="card bg-light">
							<div class="card-body">
								<h6 class="card-title text-muted">Latest Body Fat</h6>
								<h3 class="card-text">@latestMetric.FormattedBodyFatPercentage</h3>
								<small class="text-muted">@latestMetric.FormattedDate</small>
							</div>
						</div>
					</div>
				</div>

				<h4 class="mt-4 mb-3">History</h4>
				<div class="table-responsive">
					<table class="table table-hover table-striped">
						<thead class="table-dark">
							<tr>
								<th>Date</th>
								<th>Weight</th>
								<th>Body Fat %</th>
							</tr>
						</thead>
						<tbody>
							@foreach (var metric in Model)
							{
								<tr>
									<td>@metric.FormattedDate</td>
									<td>@metric.FormattedWeight</td>
									<td>@metric.FormattedBodyFatPercentage</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			}
			else
			{
				<div class="alert alert-info" role="alert">
					<i class="fas fa-info-circle"></i> No health metrics recorded yet. Your coach will log your metrics during your sessions.
				</div>
			}
		</div>
	</div>
</div>
