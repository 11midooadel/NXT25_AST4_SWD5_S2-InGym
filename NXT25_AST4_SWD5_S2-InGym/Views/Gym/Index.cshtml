@model IEnumerable<NXT25_AST4_SWD5_S2_InGym.Models.Gym>

@{
    ViewData["Title"] = "Gyms";
}

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="text-danger">Our Gyms</h2>

        <a asp-action="Create" class="btn btn-danger">
            + Add Gym
        </a>

    </div>

    <div class="row">

        @foreach (var gym in Model)
        {
            <div class="col-md-4 mb-4">

                <div class="card shadow h-100">

                    <div class="card-body">

                        <h4 class="text-danger">
                            @gym.GymName
                        </h4>

                        <hr />

                        <p>
                            <strong>Registration Date:</strong><br />
                            @gym.RegistrationDate.ToString("dd/MM/yyyy")
                        </p>

                        <p>
                            <strong>Locations:</strong>
                        </p>

                        <ul>

                            @foreach (var location in gym.GymLocations)
                            {
                                <li>@location.Location</li>
                            }

                        </ul>

                    </div>

                    <div class="card-footer text-center">

                        <a asp-action="Details"
                           asp-route-id="@gym.GymID"
                           class="btn btn-outline-primary btn-sm">

                            Details

                        </a>

                        <a asp-action="Edit"
                           asp-route-id="@gym.GymID"
                           class="btn btn-outline-warning btn-sm">

                            Edit

                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@gym.GymID"
                           class="btn btn-outline-danger btn-sm">

                            Delete

                        </a>

                    </div>

                </div>

            </div>
        }

    </div>

</div>