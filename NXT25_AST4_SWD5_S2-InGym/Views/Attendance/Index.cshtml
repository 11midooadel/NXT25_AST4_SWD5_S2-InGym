@model NXT25_AST4_SWD5_S2_InGym.ViewModels.AttendanceViewModel

@{
    ViewData["Title"] = "Attendance";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Attendance Management</h2>
        <a asp-controller="Home" asp-action="Dashboard" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to Dashboard
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <!-- Today's Attendance -->
        <div class="col-lg-4 mb-4">
            <div class="card h-100">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-calendar-day"></i> Today's Attendance
                    </h5>
                </div>
                <div class="card-body">
                    @if (!Model.CheckedIn)
                    {
                        <div class="alert alert-warning" role="alert">
                            <i class="fas fa-times-circle"></i> Not checked in yet
                        </div>
                        <a asp-action="CheckIn" class="btn btn-success w-100">
                            <i class="fas fa-sign-in-alt"></i> Check In Now
                        </a>
                    }
                    else
                    {
                        <p class="mb-3">
                            <strong>
                                <i class="fas fa-arrow-right text-success"></i> Check In Time:
                            </strong><br>
                            @Model.CheckInTime?.ToString("hh:mm tt")
                        </p>

                        @if (Model.CheckOutTime == null)
                        {
                            <div class="alert alert-info mb-3" role="alert">
                                <i class="fas fa-info-circle"></i> You're currently logged into the gym
                            </div>
                            <a asp-action="CheckOut" class="btn btn-danger w-100">
                                <i class="fas fa-sign-out-alt"></i> Check Out Now
                            </a>
                        }
                        else
                        {
                            <p class="mb-3">
                                <strong>
                                    <i class="fas fa-arrow-left text-danger"></i> Check Out Time:
                                </strong><br>
                                @Model.CheckOutTime?.ToString("hh:mm tt")
                            </p>
                            <div class="alert alert-success" role="alert">
                                <i class="fas fa-check-circle"></i> Attendance completed
                            </div>
                            <p class="text-muted">
                                <strong>Duration:</strong> 
                                @{
                                    var duration = Model.CheckOutTime.Value - Model.CheckInTime.Value;
                                    @:@($"{(int)duration.TotalHours}h {duration.Minutes}m")
                                }
                            </p>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- Statistics -->
        <div class="col-lg-8 mb-4">
            <div class="row mb-0">
                <div class="col-md-6 mb-3">
                    <div class="card bg-light">
                        <div class="card-body">
                            <h6 class="card-title text-muted">Total Check-Ins</h6>
                            <h3 class="card-text">@Model.AttendanceHistory.Count</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 mb-3">
                    <div class="card bg-light">
                        <div class="card-body">
                            <h6 class="card-title text-muted">This Month</h6>
                            <h3 class="card-text">@Model.AttendanceHistory.Count(x => x.CheckInTime.Month == DateTime.Now.Month)</h3>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-history"></i> Recent Statistics
                    </h5>
                </div>
                <div class="card-body">
                    <p class="mb-2">
                        <strong>Last Visit:</strong>
                        @if (Model.AttendanceHistory.Any())
                        {
                            <span>@Model.AttendanceHistory.First().CheckInTime.ToString("MMM dd, yyyy")</span>
                        }
                        else
                        {
                            <span class="text-muted">No visits yet</span>
                        }
                    </p>
                    <p>
                        <strong>Average Visit Duration:</strong>
                        @if (Model.AttendanceHistory.Where(x => x.CheckOutTime.HasValue).Any())
                        {
                            var avgDuration = Model.AttendanceHistory
                                .Where(x => x.CheckOutTime.HasValue)
                                .Average(x => (x.CheckOutTime.Value - x.CheckInTime).TotalMinutes);
                            <span>@($"{(int)(avgDuration / 60)}h {(int)(avgDuration % 60)}m")</span>
                        }
                        else
                        {
                            <span class="text-muted">N/A</span>
                        }
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Attendance History Table -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-table"></i> Attendance History
                    </h5>
                </div>
                <div class="card-body">
                    @if (Model.AttendanceHistory.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover table-striped">
                                <thead class="table-light">
                                    <tr>
                                        <th>Date</th>
                                        <th>Check In</th>
                                        <th>Check Out</th>
                                        <th>Duration</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.AttendanceHistory.OrderByDescending(x => x.CheckInTime))
                                    {
                                        <tr>
                                            <td>@item.CheckInTime.ToString("MMM dd, yyyy")</td>
                                            <td>@item.CheckInTime.ToString("hh:mm tt")</td>
                                            <td>
                                                @if (item.CheckOutTime.HasValue)
                                                {
                                                    @item.CheckOutTime?.ToString("hh:mm tt")
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning">Still inside</span>
                                                }
                                            </td>
                                            <td>
                                                @if (item.CheckOutTime.HasValue)
                                                {
                                                    var duration = item.CheckOutTime.Value - item.CheckInTime;
                                                    @($"{(int)duration.TotalHours}h {duration.Minutes}m")
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (item.CheckOutTime.HasValue)
                                                {
                                                    <span class="badge bg-success">Completed</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-info">Active</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info" role="alert">
                            <i class="fas fa-info-circle"></i> No attendance records found. Start by checking in!
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

</div>