@model DietaryPlan
@{
    ViewData["Title"] = "Edit Diet Plan";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h2 class="mb-4">Edit Diet Plan</h2>

            <form method="post" asp-action="EditDietPlan" class="needs-validation">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.DietID" />

                <div class="card">
                    <div class="card-body">
                        <!-- Goal -->
                        <div class="mb-3">
                            <label asp-for="Goal" class="form-label"><strong>Diet Goal</strong></label>
                            <input asp-for="Goal" class="form-control" />
                            <span asp-validation-for="Goal" class="text-danger"></span>
                        </div>

                        <!-- Description -->
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label"><strong>Description</strong></label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <hr />

                        <!-- Macros Section -->
                        <h5 class="mb-3">Daily Macronutrient Targets</h5>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Calories" class="form-label"><strong>Calories (kcal)</strong></label>
                                <input asp-for="Calories" type="number" class="form-control" />
                                <span asp-validation-for="Calories" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Protein" class="form-label"><strong>Protein (g)</strong></label>
                                <input asp-for="Protein" type="number" class="form-control" />
                                <span asp-validation-for="Protein" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Carbs" class="form-label"><strong>Carbohydrates (g)</strong></label>
                                <input asp-for="Carbs" type="number" class="form-control" />
                                <span asp-validation-for="Carbs" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Fats" class="form-label"><strong>Fats (g)</strong></label>
                                <input asp-for="Fats" type="number" class="form-control" />
                                <span asp-validation-for="Fats" class="text-danger"></span>
                            </div>
                        </div>

                        <hr />

                        <!-- Dates Section -->
                        <h5 class="mb-3">Plan Duration</h5>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="StartDate" class="form-label"><strong>Start Date</strong></label>
                                <input asp-for="StartDate" type="date" class="form-control" />
                                <span asp-validation-for="StartDate" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="EndDate" class="form-label"><strong>End Date</strong></label>
                                <input asp-for="EndDate" type="date" class="form-control" />
                                <span asp-validation-for="EndDate" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- Active Status -->
                        <div class="mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" asp-for="IsActive" id="isActive" />
                                <label class="form-check-label" for="isActive">
                                    <strong>Plan is Active</strong>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Buttons -->
                <div class="mt-4">
                    <button type="submit" class="btn btn-success btn-lg">
                        <i class="bi bi-check-circle"></i> Update Diet Plan
                    </button>
                    <a href="javascript:history.back()" class="btn btn-secondary btn-lg">
                        <i class="bi bi-x-circle"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
