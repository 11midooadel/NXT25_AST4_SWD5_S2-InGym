@model List<WorkoutPlan>
@{
    ViewData["Title"] = "Diet Plans";
    var memberId = (int)ViewBag.MemberID;
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>Diet Plans for Member</h2>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("CreateDietPlan", new { memberId })" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Create Diet Plan
            </a>
            <a href="@Url.Action("ManageMember", "Coach", new { id = memberId })" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    @if (Model?.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Goal</th>
                        <th>Calories</th>
                        <th>Protein (g)</th>
                        <th>Carbs (g)</th>
                        <th>Fats (g)</th>
                        <th>Duration</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var plan in Model)
                    {
                        <tr>
                            <td><strong>@plan.Goal</strong></td>
                            <td>@plan.Calories kcal</td>
                            <td>@plan.Protein g</td>
                            <td>@plan.Carbs g</td>
                            <td>@plan.Fats g</td>
                            <td>@plan.StartDate.ToString("dd/MM/yyyy") - @plan.EndDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (plan.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>
                                <a href="@Url.Action("ViewDietPlan", new { id = plan.PlanID })" class="btn btn-sm btn-info">
                                    <i class="bi bi-eye"></i> View
                                </a>
                                <a href="@Url.Action("EditDietPlan", new { id = plan.PlanID })" class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <form method="post" action="@Url.Action("DeleteDietPlan")" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@plan.PlanID" />
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?')">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            <i class="bi bi-info-circle"></i> No diet plans assigned yet.
            <a href="@Url.Action("CreateDietPlan", new { memberId })" class="alert-link">Create one now</a>
        </div>
    }
</div>
