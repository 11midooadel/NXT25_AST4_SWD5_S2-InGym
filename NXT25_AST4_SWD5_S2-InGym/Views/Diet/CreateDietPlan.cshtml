@model DietaryPlan
@{
    ViewData["Title"] = "Create Diet Plan";
    var memberId = (int)ViewBag.MemberID;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h2 class="mb-4">Create New Diet Plan</h2>

            <form method="post" asp-action="CreateDietPlan" asp-controller="Diet" class="needs-validation">
                @Html.AntiForgeryToken()
                <input type="hidden" name="memberId" value="@memberId" />

                <div class="card">
                    <div class="card-body">
                        <!-- Goal -->
                        <div class="mb-3">
                            <label asp-for="Goal" class="form-label"><strong>Diet Goal</strong></label>
                            <input asp-for="Goal" class="form-control" placeholder="e.g., Weight Loss, Muscle Gain" />
                            <span asp-validation-for="Goal" class="text-danger"></span>
                        </div>

                        <!-- Description -->
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label"><strong>Description</strong></label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Add diet details and notes"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <hr />

                        <!-- Macros Section -->
                        <h5 class="mb-3">Daily Macronutrient Targets</h5>

                        <div class="row">
                            <!-- Calories -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Calories" class="form-label"><strong>Calories (kcal)</strong></label>
                                <input asp-for="Calories" type="number" class="form-control" placeholder="2000" />
                                <span asp-validation-for="Calories" class="text-danger"></span>
                            </div>

                            <!-- Protein -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Protein" class="form-label"><strong>Protein (g)</strong></label>
                                <input asp-for="Protein" type="number" class="form-control" placeholder="100" />
                                <span asp-validation-for="Protein" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <!-- Carbs -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Carbs" class="form-label"><strong>Carbohydrates (g)</strong></label>
                                <input asp-for="Carbs" type="number" class="form-control" placeholder="200" />
                                <span asp-validation-for="Carbs" class="text-danger"></span>
                            </div>

                            <!-- Fats -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Fats" class="form-label"><strong>Fats (g)</strong></label>
                                <input asp-for="Fats" type="number" class="form-control" placeholder="50" />
                                <span asp-validation-for="Fats" class="text-danger"></span>
                            </div>
                        </div>

                        <hr />

                        <!-- Dates Section -->
                        <h5 class="mb-3">Plan Duration</h5>

                        <div class="row">
                            <!-- Start Date -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="StartDate" class="form-label"><strong>Start Date</strong></label>
                                <input asp-for="StartDate" type="date" class="form-control" />
                                <span asp-validation-for="StartDate" class="text-danger"></span>
                            </div>

                            <!-- End Date -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="EndDate" class="form-label"><strong>End Date</strong></label>
                                <input asp-for="EndDate" type="date" class="form-control" />
                                <span asp-validation-for="EndDate" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Buttons -->
                <div class="mt-4">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-check-circle"></i> Create Diet Plan
                    </button>
                    <a href="@Url.Action("DietPlans", new { memberId })" class="btn btn-secondary btn-lg">
                        <i class="bi bi-x-circle"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
