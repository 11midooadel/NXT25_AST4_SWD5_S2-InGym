@model DietaryPlan
@{
    ViewData["Title"] = "Diet Plan Details";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>@Model.Goal</h2>
            <p class="text-muted">Created: @Model.CreationDate.ToString("dd MMM yyyy")</p>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("EditDietPlan", new { id = Model.DietID })" class="btn btn-warning">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <a href="javascript:history.back()" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    <div class="row">
        <!-- Description Card -->
        <div class="col-md-12 mb-4">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Diet Description</h5>
                </div>
                <div class="card-body">
                    <p>@Model.Description</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Macronutrients -->
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">Daily Macronutrients</h5>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-md-6 mb-3">
                            <h6 class="text-muted">Calories</h6>
                            <h3 class="text-primary">@Model.Calories <small>kcal</small></h3>
                        </div>
                        <div class="col-md-6 mb-3">
                            <h6 class="text-muted">Protein</h6>
                            <h3 class="text-success">@Model.Protein <small>g</small></h3>
                        </div>
                    </div>
                    <div class="row text-center">
                        <div class="col-md-6 mb-3">
                            <h6 class="text-muted">Carbs</h6>
                            <h3 class="text-warning">@Model.Carbs <small>g</small></h3>
                        </div>
                        <div class="col-md-6 mb-3">
                            <h6 class="text-muted">Fats</h6>
                            <h3 class="text-danger">@Model.Fats <small>g</small></h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Plan Duration & Status -->
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0">Plan Duration & Status</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <h6 class="text-muted">Start Date</h6>
                        <p><strong>@Model.StartDate.ToString("dd MMM yyyy")</strong></p>
                    </div>
                    <div class="mb-3">
                        <h6 class="text-muted">End Date</h6>
                        <p><strong>@Model.EndDate.ToString("dd MMM yyyy")</strong></p>
                    </div>
                    <div class="mb-3">
                        <h6 class="text-muted">Duration</h6>
                        <p><strong>@((Model.EndDate - Model.StartDate).Days) days</strong></p>
                    </div>
                    <div>
                        <h6 class="text-muted">Status</h6>
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success fs-6">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary fs-6">Inactive</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
