@model NXT25_AST4_SWD5_S2_InGym.ViewModels.Coach.EditExerciseViewModel

<h2>Edit Exercise</h2>

<form asp-action="EditExercise" method="post">

    <input asp-for="PlanID" type="hidden" />
    <input asp-for="ExerciseID" type="hidden" />

    <div class="mb-3">
        <label>Exercise</label>

        <select asp-for="ExerciseID"
                asp-items="Model.Exercises"
                class="form-select"
                disabled>
        </select>
    </div>

    <div class="mb-3">
        <label>Workout Day</label>

        <select asp-for="WorkoutDay"
                asp-items="Html.GetEnumSelectList<DayOfWeek>()"
                class="form-select">
        </select>
    </div>

    <div class="mb-3">
        <label>Sets</label>

        <input asp-for="Sets"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Reps</label>

        <input asp-for="Reps"
               class="form-control" />
    </div>

    <button class="btn btn-primary">
        Update
    </button>

</form>