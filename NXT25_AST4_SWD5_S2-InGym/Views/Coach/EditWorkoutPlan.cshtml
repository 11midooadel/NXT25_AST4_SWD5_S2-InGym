@model WorkoutPlan
@{
    ViewData["Title"] = "Edit Workout Plan";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h2 class="mb-4">Edit Workout Plan</h2>

            <form method="post" asp-action="EditWorkoutPlan" asp-controller="Coach" class="needs-validation">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.PlanID" />

                <div class="card">
                    <div class="card-body">
                        <!-- Goal -->
                        <div class="mb-3">
                            <label asp-for="Goal" class="form-label"><strong>Workout Goal</strong></label>
                            <input asp-for="Goal" class="form-control" placeholder="e.g., Strength Training" />
                            <span asp-validation-for="Goal" class="text-danger"></span>
                        </div>

                        <hr />

                        <!-- Plan Duration -->
                        <h5 class="mb-3">Plan Duration</h5>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="StartDate" class="form-label"><strong>Start Date</strong></label>
                                <input asp-for="StartDate" type="date" class="form-control" />
                                <span asp-validation-for="StartDate" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="EndDate" class="form-label"><strong>End Date</strong></label>
                                <input asp-for="EndDate" type="date" class="form-control" />
                                <span asp-validation-for="EndDate" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- Active Status -->
                        <div class="mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" asp-for="IsActive" id="isActive" />
                                <label class="form-check-label" for="isActive">
                                    <strong>Plan is Active</strong>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Buttons -->
                <div class="mt-4">
                    <button type="submit" class="btn btn-success btn-lg">
                        <i class="bi bi-check-circle"></i> Update Plan
                    </button>
                    <a href="javascript:history.back()" class="btn btn-secondary btn-lg">
                        <i class="bi bi-x-circle"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
