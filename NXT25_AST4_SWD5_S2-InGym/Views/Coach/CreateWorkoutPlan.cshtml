@model NXT25_AST4_SWD5_S2_InGym.ViewModels.Coach.CreateWorkoutPlanViewModel

@{
    ViewData["Title"] = "Create Workout Plan";
}

<div class="container mt-4">

    <h2>Create Workout Plan</h2>

    <form asp-action="CreateWorkoutPlan" method="post">

        <input asp-for="MemberID" type="hidden" />

        <div class="mb-3">
            <label asp-for="Goal"></label>
            <input asp-for="Goal" class="form-control" />
            <span asp-validation-for="Goal" class="text-danger"></span>
        </div>

        <div class="mb-3">

            <label>Select Exercises</label>

            @foreach (var exercise in Model.Exercises)
            {
                <div class="form-check">

                    <input class="form-check-input"
                           type="checkbox"
                           name="SelectedExercises"
                           value="@exercise.Value" />

                    <label class="form-check-label">
                        @exercise.Text
                    </label>

                </div>
            }

        </div>

        <button class="btn btn-success">
            Save Workout Plan
        </button>

    </form>

</div>