@model NXT25_AST4_SWD5_S2_InGym.Models.Member

@{
    ViewData["Title"] = "Manage Member";
}

<div class="container mt-4">

    <h2 class="mb-4">
        Manage Member
    </h2>

    <div class="card shadow">

        <div class="card-body">

            <h4>
                @Model.User.FirstName @Model.User.LastName
            </h4>

            <p>
                <strong>Email:</strong>
                @Model.User.Email
            </p>

            <hr />

            <div class="row">

                <div class="col-md-4">

                    <a asp-action="WorkoutPlans"
                       asp-route-memberId="@Model.MemberID"
                       class="btn btn-primary w-100">
                        Workout Plans
                    </a>

                </div>

                <div class="col-md-4">

                    <a class="btn btn-success w-100">
                        Diet Plans
                    </a>

                </div>

                <div class="col-md-4">

                    <a class="btn btn-warning w-100">
                        Health Metrics
                    </a>

                </div>

            </div>

        </div>

    </div>

</div>