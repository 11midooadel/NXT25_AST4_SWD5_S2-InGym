@model IEnumerable<NXT25_AST4_SWD5_S2_InGym.ViewModels.PrivateCoachViewModel>

@{
    ViewData["Title"] = "Choose Private Coach";
}

<h2 class="text-center mb-4">
    Choose Your Private Trainer
</h2>

<div class="row">

    @foreach (var coach in Model)
    {
        <div class="col-md-4 mb-4">

            <div class="card shadow h-100">

                <div class="card-header bg-dark text-white">
                    @coach.FullName
                </div>

                <div class="card-body">

                    <p><strong>Email:</strong> @coach.Email</p>

                    <p><strong>Speciality:</strong> @coach.Speciality</p>

                    <p><strong>Rating:</strong> ⭐ @coach.Rating</p>

                    <a asp-action="ChoosePackage"
                       asp-route-coachId="@coach.CoachID"
                       class="btn btn-success w-100">

                        Select Coach

                    </a>

                </div>

            </div>

        </div>
    }

</div>