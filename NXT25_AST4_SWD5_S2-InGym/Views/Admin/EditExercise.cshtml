@model NXT25_AST4_SWD5_S2_InGym.Models.Exercise

@{
	ViewData["Title"] = "Edit Exercise";
}

<div class="container mt-4">
	<div class="row">
		<div class="col-md-8 offset-md-2">
			<h2 class="mb-4">Edit Exercise</h2>

			<form asp-action="EditExercise" method="post" class="needs-validation">
				<input asp-for="ExerciseID" type="hidden" />

				<div class="mb-3">
					<label asp-for="ExerciseName" class="form-label">Exercise Name</label>
					<input asp-for="ExerciseName" class="form-control" />
					<span asp-validation-for="ExerciseName" class="text-danger small"></span>
				</div>

				<div class="mb-3">
					<label asp-for="MuscleGroup" class="form-label">Muscle Group</label>
					<input asp-for="MuscleGroup" class="form-control" />
					<span asp-validation-for="MuscleGroup" class="text-danger small"></span>
				</div>

				<div class="mb-3">
					<label asp-for="Description" class="form-label">Description</label>
					<textarea asp-for="Description" class="form-control" rows="4"></textarea>
					<small class="form-text text-muted">Optional</small>
				</div>

				<div class="d-flex gap-2">
					<button type="submit" class="btn btn-primary">
						<i class="fas fa-save"></i> Update Exercise
					</button>
					<a asp-action="Exercises" class="btn btn-secondary">
						<i class="fas fa-arrow-left"></i> Cancel
					</a>
				</div>
			</form>
		</div>
	</div>
</div>

@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}
}
