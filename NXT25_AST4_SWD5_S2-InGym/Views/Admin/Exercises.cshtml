@model List<NXT25_AST4_SWD5_S2_InGym.Models.Exercise>

@{
	ViewData["Title"] = "Manage Exercises";
}

<div class="container mt-4">
	<div class="row">
		<div class="col-md-12">
			<div class="d-flex justify-content-between align-items-center mb-4">
				<h2>Exercises</h2>
				<div class="d-flex gap-2">
					<a asp-action="AddExercise" class="btn btn-primary">
						<i class="fas fa-plus"></i> Add Exercise
					</a>
					<a asp-action="Dashboard" class="btn btn-secondary">
						<i class="fas fa-arrow-left"></i> Back
					</a>
				</div>
			</div>

			@if (Model.Any())
			{
				<div class="table-responsive">
					<table class="table table-hover table-striped">
						<thead class="table-dark">
							<tr>
								<th>Name</th>
								<th>Muscle Group</th>
								<th>Description</th>
								<th>Actions</th>
							</tr>
						</thead>
						<tbody>
							@foreach (var exercise in Model)
							{
								<tr>
									<td>@exercise.ExerciseName</td>
									<td><span class="badge bg-info">@exercise.MuscleGroup</span></td>
									<td>@(string.IsNullOrEmpty(exercise.Description) ? "N/A" : exercise.Description.Substring(0, Math.Min(50, exercise.Description.Length)) + "...")</td>
									<td>
										<a asp-action="EditExercise" asp-route-id="@exercise.ExerciseID" class="btn btn-sm btn-warning">
											<i class="fas fa-edit"></i> Edit
										</a>
										<form asp-action="DeleteExercise" method="post" style="display:inline;" 
											  onsubmit="return confirm('Are you sure you want to delete this exercise?');">
											<input type="hidden" name="id" value="@exercise.ExerciseID" />
											<button type="submit" class="btn btn-sm btn-danger">
												<i class="fas fa-trash"></i> Delete
											</button>
										</form>
									</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			}
			else
			{
				<div class="alert alert-info" role="alert">
					<i class="fas fa-info-circle"></i> No exercises found.
					<a asp-action="AddExercise" class="alert-link">Create one now</a>
				</div>
			}
		</div>
	</div>
</div>
