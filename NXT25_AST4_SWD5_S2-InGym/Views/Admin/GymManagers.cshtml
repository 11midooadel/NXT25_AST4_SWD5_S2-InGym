@model IEnumerable<NXT25_AST4_SWD5_S2_InGym.Models.GymManager>

@{
    ViewData["Title"] = "Gym Managers";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2>Gym Managers</h2>

        <a asp-action="AddGymManager" class="btn btn-success">
            Add Gym Manager
        </a>

    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    <table class="table table-bordered table-hover shadow">

        <thead class="table-dark">

            <tr>
                <th>#</th>
                <th>Full Name</th>
                <th>Email</th>
                <th>Gym</th>
                <th>Salary</th>
                <th>Hire Date</th>
            </tr>

        </thead>

        <tbody>

            @{
                int i = 1;
            }

            @foreach (var item in Model)
            {
                <tr>

                    <td>@i</td>

                    <td>
                        @item.User.FirstName @item.User.LastName
                    </td>

                    <td>
                        @item.User.Email
                    </td>

                    <td>
                        @item.Gym.GymName
                    </td>

                    <td>
                        @item.Salary EGP
                    </td>

                    <td>
                        @item.HireDate.ToString("dd/MM/yyyy")
                    </td>

                </tr>

                i++;
            }

        </tbody>

    </table>

</div>