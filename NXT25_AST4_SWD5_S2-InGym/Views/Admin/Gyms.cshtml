@model IEnumerable<NXT25_AST4_SWD5_S2_InGym.Models.Gym>

@{
    ViewData["Title"] = "Gyms";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2>Manage Gyms</h2>

        <a asp-action="AddGym" class="btn btn-success">
            + Add Gym
        </a>

    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    <table class="table table-bordered table-hover shadow">

        <thead class="table-dark">

            <tr>

                <th>#</th>

                <th>Gym Name</th>

                <th>Location</th>

                <th>Managers</th>

                <th>Actions</th>

            </tr>

        </thead>

        <tbody>

            @foreach (var gym in Model)
            {
                <tr>

                    <td>@gym.GymID</td>

                    <td>@gym.GymName</td>

                    <td>@gym.GymLocations.FirstOrDefault()?.Location</td>

                    <td>@gym.GymManagers.Count()</td>

                    <td>

                        <a asp-action="GymDetails"
                           asp-route-id="@gym.GymID"
                           class="btn btn-primary btn-sm">

                            Details

                        </a>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>