@model NXT25_AST4_SWD5_S2_InGym.ViewModels.Admin.AddGymViewModel

@{
    ViewData["Title"] = "Add Gym";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card shadow">

                <div class="card-header bg-primary text-white">

                    <h4 class="mb-0">
                        Add New Gym
                    </h4>

                </div>

                <div class="card-body">

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">
                            @TempData["Success"]
                        </div>
                    }

                    <form asp-action="AddGym" method="post">

                        <div asp-validation-summary="ModelOnly"
                             class="text-danger mb-3">
                        </div>

                        <div class="mb-3">

                            <label asp-for="GymName"
                                   class="form-label">
                            </label>

                            <input asp-for="GymName"
                                   class="form-control" />

                            <span asp-validation-for="GymName"
                                  class="text-danger">
                            </span>

                        </div>

                        <div class="mb-4">

                            <label asp-for="Location"
                                   class="form-label">
                            </label>

                            <input asp-for="Location"
                                   class="form-control" />

                            <span asp-validation-for="Location"
                                  class="text-danger">
                            </span>

                        </div>

                        <button class="btn btn-success w-100">

                            Save Gym

                        </button>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}