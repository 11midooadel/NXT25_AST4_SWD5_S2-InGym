@model List<NXT25_AST4_SWD5_S2_InGym.ViewModels.Coach.DietPlanViewModel>

@{
	ViewData["Title"] = "Diet Plans";
}

<div class="container mt-4">
	<div class="row">
		<div class="col-md-10 offset-md-1">
			<div class="d-flex justify-content-between align-items-center mb-4">
				<div>
					<h2>Diet Plans</h2>
					@if (Model.Any())
					{
						<p class="text-muted">Member: <strong>@Model.First().MemberName</strong></p>
					}
				</div>
				<div class="d-flex gap-2">
					@if (Model.Any())
					{
						<a asp-action="CreateDietPlan" asp-route-memberId="@Model.First().MemberId" class="btn btn-primary">
							<i class="fas fa-plus"></i> New Diet Plan
						</a>
					}
					<a href="javascript:history.back()" class="btn btn-secondary">
						<i class="fas fa-arrow-left"></i> Back
					</a>
				</div>
			</div>

			@if (Model.Any())
			{
				<div class="row">
					@foreach (var plan in Model)
					{
						<div class="col-md-6 mb-3">
							<div class="card h-100">
								<div class="card-body">
									<h5 class="card-title">Diet Plan</h5>
									<p class="card-text">
										<strong>Calorie Target:</strong> @plan.CalorieTarget kcal<br />
										<strong>Protein Target:</strong> @plan.ProteinTarget g<br />
										<strong>Created:</strong> @plan.FormattedDate
									</p>
									@if (!string.IsNullOrEmpty(plan.Notes))
									{
										<p class="card-text text-muted"><strong>Notes:</strong> @plan.Notes</p>
									}
								</div>
								<div class="card-footer bg-light">
									<a asp-action="EditDietPlan" asp-route-dietId="@plan.DietID" asp-route-memberId="@plan.MemberId" class="btn btn-sm btn-warning">
										<i class="fas fa-edit"></i> Edit
									</a>
									<form asp-action="DeleteDietPlan" method="post" style="display:inline;" 
										  onsubmit="return confirm('Are you sure you want to delete this diet plan?');">
										<input type="hidden" name="dietId" value="@plan.DietID" />
										<input type="hidden" name="memberId" value="@plan.MemberId" />
										<button type="submit" class="btn btn-sm btn-danger">
											<i class="fas fa-trash"></i> Delete
										</button>
									</form>
								</div>
							</div>
						</div>
					}
				</div>
			}
			else
			{
				<div class="alert alert-info" role="alert">
					<i class="fas fa-info-circle"></i> No diet plans created yet.
					<a asp-action="CreateDietPlan" asp-route-memberId="@ViewBag.MemberId" class="alert-link">Create one now</a>
				</div>
			}
		</div>
	</div>
</div>
