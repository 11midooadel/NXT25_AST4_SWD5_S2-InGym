@page
@model NXT25_AST4_SWD5_S2_InGym.Pages.Members.DetailsModel

@{
	ViewData["Title"] = "Member Details";
}

<div class="container mt-4">
	<div class="row">
		<div class="col-md-6">
			<h1>@Model.User.Name</h1>
			<dl class="row">
				<dt class="col-sm-3">ID</dt>
				<dd class="col-sm-9">@Model.User.Id</dd>

				<dt class="col-sm-3">Role</dt>
				<dd class="col-sm-9"><span class="badge bg-info">@Model.User.Role</span></dd>

				<dt class="col-sm-3">Date Joined</dt>
				<dd class="col-sm-9">@Model.User.DateJoined.ToString("MM/dd/yyyy HH:mm:ss")</dd>
			</dl>

			<div class="mt-3">
				<a asp-page="Edit" asp-route-id="@Model.User.Id" class="btn btn-warning">Edit</a>
				<a asp-page="Delete" asp-route-id="@Model.User.Id" class="btn btn-danger">Delete</a>
				<a asp-page="Index" class="btn btn-secondary">Back to List</a>
			</div>
		</div>
	</div>
</div>
