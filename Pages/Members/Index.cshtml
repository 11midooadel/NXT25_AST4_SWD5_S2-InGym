@page
@model NXT25_AST4_SWD5_S2_InGym.Pages.Members.IndexModel

@{
	ViewData["Title"] = "Members";
}

<div class="container-fluid">
	<div class="row mb-3">
		<div class="col">
			<h1>Members</h1>
		</div>
		<div class="col-auto">
			<a asp-page="Create" class="btn btn-primary">Add New Member</a>
		</div>
	</div>

	@if (Model.Users.Any())
	{
		<div class="table-responsive">
			<table class="table table-striped table-hover">
				<thead class="table-dark">
					<tr>
						<th>ID</th>
						<th>Name</th>
						<th>Role</th>
						<th>Date Joined</th>
						<th>Actions</th>
					</tr>
				</thead>
				<tbody>
					@foreach (var user in Model.Users)
					{
						<tr>
							<td>@user.Id</td>
							<td>@user.Name</td>
							<td><span class="badge bg-info">@user.Role</span></td>
							<td>@user.DateJoined.ToString("MM/dd/yyyy")</td>
							<td>
								<a asp-page="Details" asp-route-id="@user.Id" class="btn btn-sm btn-info">View</a>
								<a asp-page="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-warning">Edit</a>
								<a asp-page="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-danger">Delete</a>
							</td>
						</tr>
					}
				</tbody>
			</table>
		</div>
	}
	else
	{
		<div class="alert alert-info">No members found. <a asp-page="Create">Create one now</a>.</div>
	}
</div>
