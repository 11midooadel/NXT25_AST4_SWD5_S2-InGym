@page
@model NXT25_AST4_SWD5_S2_InGym.Pages.Members.EditModel

@{
	ViewData["Title"] = "Edit Member";
}

<div class="container mt-4">
	<div class="row">
		<div class="col-md-6">
			<h1>Edit Member</h1>
			<form method="post">
				<div class="mb-3">
					<input type="hidden" asp-for="User.Id" />
					<input type="hidden" asp-for="User.DateJoined" />
				</div>

				<div class="mb-3">
					<label asp-for="User.Name" class="form-label">Name</label>
					<input asp-for="User.Name" class="form-control" />
					<span asp-validation-for="User.Name" class="text-danger"></span>
				</div>

				<div class="mb-3">
					<label asp-for="User.Role" class="form-label">Role</label>
					<select asp-for="User.Role" class="form-select">
						<option value="Admin">Admin</option>
						<option value="Trainer">Trainer</option>
						<option value="Trainee">Trainee</option>
					</select>
					<span asp-validation-for="User.Role" class="text-danger"></span>
				</div>

				<div class="form-group">
					<button type="submit" class="btn btn-success">Save</button>
					<a asp-page="Index" class="btn btn-secondary">Cancel</a>
				</div>
			</form>
		</div>
	</div>
</div>

@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}
}
