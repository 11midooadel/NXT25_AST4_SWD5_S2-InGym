@model AnalyticsViewModel;
@{
    ViewData["Title"] = "Home";
}

<div class="row align-items-center mb-5">
    <div class="col-md-6 col-lg-7 col-12">
        <div class="info mt-4">
            <header>
                <h2 class="fw-bolder display-4 mb-4" style="color: var(--clr-text-dark);">
                    Your body can
                    <span class="text-primary-custom">stand almost</span> anything
                </h2>

                <p class="mb-5" style="color: var(--clr-text-muted); font-size: 1.1rem; line-height: 1.6;">
                    It's your mind that needs convincing. Push past your limits,
                    stay committed, and watch as your body transforms into a powerhouse of
                    strength and resilience. Start your journey today and discover what you're truly
                    capable of!
                </p>
            </header>

            <div class="stats-bar mb-5">
                <div class="row g-3">
                    <div class="col-4">
                        <div class="stat-card text-center py-3 px-2">
                            <span class="fw-bolder fs-4 d-block text-primary-custom mb-1">@Model.TotalMembers</span>
                            <h3 class="fs-6 fw-normal text-muted m-0">Total Members</h3>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="stat-card text-center py-3 px-2">
                            <span class="fw-bolder fs-4 d-block text-primary-custom mb-1">@Model.ActiveMembers</span>
                            <h3 class="fs-6 fw-normal text-muted m-0">Active Members</h3>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="stat-card text-center py-3 px-2">
                            <span class="fw-bolder fs-4 d-block text-primary-custom mb-1">@Model.TotalTrainers</span>
                            <h3 class="fs-6 fw-normal text-muted m-0">Trainers</h3>
                        </div>
                    </div>
                </div>
                <div class="row g-3 mt-1">
                    <div class="col-4">
                        <div class="stat-card text-center py-3 px-2">
                            <span class="fw-bolder fs-4 d-block text-primary-custom mb-1">@Model.UpcomingSessions</span>
                            <h3 class="fs-6 fw-normal text-muted m-0">Upcoming Sessions</h3>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="stat-card text-center py-3 px-2">
                            <span class="fw-bolder fs-4 d-block text-primary-custom mb-1">@Model.OngoingSessions</span>
                            <h3 class="fs-6 fw-normal text-muted m-0">Ongoing Sessions</h3>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="stat-card text-center py-3 px-2">
                            <span class="fw-bolder fs-4 d-block text-primary-custom mb-1">@Model.CompletedSessions</span>
                            <h3 class="fs-6 fw-normal text-muted m-0">Completed Sessions</h3>
                        </div>
                    </div>
                </div>
            </div>

            <div class="buttons my-4 d-flex gap-3">
                <button class="btn-fill rounded-pill px-4 py-2" onclick="location.href = '/Session/Index'">
                    Get Started
                </button>
                <button class="btn-outline rounded-pill px-4 py-2" onclick="location.href = '/Plan/Index'">
                    Explore More
                </button>
            </div>
        </div>
    </div>

    <div class="col-md-5 offset-md-0 col-12 order-first order-md-last mt-4 mt-md-0">
        <div class="character d-flex justify-content-center position-relative">
            <!-- Consider replacing with a modern high-res image, adding rounded corners -->
            <img src="~/images/Theo Vance.jpg" alt="Theo Vance" class="img-fluid rounded-4 shadow-lg" />
        </div>
    </div>
</div>

<div class="bar bg-primary-custom d-flex py-3 text-white fw-bolder align-items-center justify-content-center rounded-4 shadow">
    <p class="py-0 my-0 overflow-hidden text-nowrap d-flex align-items-center gap-3 fs-5">
        Outdoor & online trainers
        <i class="fa-solid fa-star" style="color: var(--clr-accent);"></i> Personal training
        <i class="fa-solid fa-star" style="color: var(--clr-accent);"></i> Live classes
        <i class="fa-solid fa-star" style="color: var(--clr-accent);"></i> Personal trainers
        <i class="fa-solid fa-star" style="color: var(--clr-accent);"></i> Personal training
    </p>
</div>

<!-- ^ all other section -->
<main>
    <!-- ^ about section -->
    <section class="about my-5 py-5">
        <div class="container">
            <div class="row g-5 justify-content-center align-items-center">
                <div class="col-12 col-lg-6 w-50 w-md-100">
                    <div class="characters position-relative">
                        <div class="image">
                            <img class="img-fluid rounded-4 shadow" src="~/images/about p1.jpg" alt="person" style="max-height: 600px;" />
                        </div>
                        <div class="image position-absolute d-none d-lg-block" style="top: -30px; right: -30px; z-index: -1;">
                            <img class="img-fluid rounded-4 shadow" src="~/images/about p2.jpg" alt="person" style="max-height: 600px;" />
                        </div>
                    </div>
                </div>

                <div class="col-12 col-lg-6">
                    <div class="title d-flex justify-content-start align-items-center gap-2 mb-3">
                        <i class="fa-solid fa-dumbbell fs-3 text-primary-custom"></i>
                        <h2 class="text-primary-custom fs-5 m-0 text-uppercase fw-bold">About Us</h2>
                    </div>

                    <header>
                        <h3 class="fw-bolder display-6 mb-4" style="color: var(--clr-text-dark);">
                            EMPOWERING YOU TO ACHIEVE
                            <span class="text-primary-custom">YOUR FITNESS</span> GOALS
                        </h3>
                        <p class="text" style="color: var(--clr-text-muted); line-height: 1.7;">
                            We believe fitness is more than just a workout—it's a
                            lifestyle. With top-of-the-line facilities, certified
                            trainers, and a supportive community, we're here to inspire
                            and guide you every step of the way.
                        </p>
                    </header>

                    <div class="features mt-5">
                        <div class="row row-cols-1 row-cols-sm-2 gx-4 gy-4">
                            <!-- Feature 1 -->
                            <div class="feature">
                                <div class="inner d-flex align-items-start gap-3">
                                    <div class="icon-box text-primary-custom fs-3">
                                        <i class="fa-solid fa-user-tie"></i>
                                    </div>
                                    <div class="info">
                                        <h4 class="fw-bold fs-6 mb-2" style="color: var(--clr-text-dark);">Personal Trainer</h4>
                                        <p class="small m-0" style="color: var(--clr-text-muted);">Achieve your fitness goals with the guidance of our certified trainers.</p>
                                    </div>
                                </div>
                            </div>

                            <!-- Feature 2 -->
                            <div class="feature">
                                <div class="inner d-flex align-items-start gap-3">
                                    <div class="icon-box text-primary-custom fs-3">
                                        <i class="fa-solid fa-heart-pulse"></i>
                                    </div>
                                    <div class="info">
                                        <h4 class="fw-bold fs-6 mb-2" style="color: var(--clr-text-dark);">Health Focused</h4>
                                        <p class="small m-0" style="color: var(--clr-text-muted);">Achieve your fitness goals with the guidance of our certified trainers.</p>
                                    </div>
                                </div>
                            </div>

                            <!-- Feature 3 -->
                            <div class="feature">
                                <div class="inner d-flex align-items-start gap-3">
                                    <div class="icon-box text-primary-custom fs-3">
                                        <i class="fa-solid fa-stopwatch"></i>
                                    </div>
                                    <div class="info">
                                        <h4 class="fw-bold fs-6 mb-2" style="color: var(--clr-text-dark);">Flexible Timing</h4>
                                        <p class="small m-0" style="color: var(--clr-text-muted);">Achieve your fitness goals with the guidance of our certified trainers.</p>
                                    </div>
                                </div>
                            </div>

                            <!-- Feature 4 -->
                            <div class="feature">
                                <div class="inner d-flex align-items-start gap-3">
                                    <div class="icon-box text-primary-custom fs-3">
                                        <i class="fa-solid fa-ranking-star"></i>
                                    </div>
                                    <div class="info">
                                        <h4 class="fw-bold fs-6 mb-2" style="color: var(--clr-text-dark);">Top Equipment</h4>
                                        <p class="small m-0" style="color: var(--clr-text-muted);">Achieve your fitness goals with the guidance of our certified trainers.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <button class="btn-fill rounded-pill mt-5" onclick="location.href = '/Session/Index'">
                            Get Started
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ^ workout section -->
    <section class="workout py-5 bg-primary-custom text-white position-relative rounded-4 shadow">
        <div class="container mt-5">
            <div class="title text-center mb-5">
                <h2 class="text-white opacity-50 mb-2">WORKOUTS</h2>
                <p class="text-white fw-bolder fs-2 mb-4 mx-auto" style="max-width: 600px;">
                    Transform Your Body with Our Dynamic Upcoming Workouts
                </p>
            </div>

            <div class="row row-cols-md-3 row-cols-12 gy-4 gx-4">
                <div>
                    <div class="card plan-card border-0">
                        <img src="~/images/workout 1.jpg" class="card-img-top rounded-top-3" alt="..." style="height: 250px; object-fit: cover;" />
                        <footer class="card-footer bg-white border-0 text-center py-4">
                            <h5 class="card-title text-uppercase fw-bolder" style="color: var(--clr-primary);">
                                group workout
                            </h5>
                            <a href="#" class="text-decoration-none fw-semibold" style="color: var(--clr-text-muted);">Explore <i class="fa-solid fa-arrow-right ms-1"></i></a>
                        </footer>
                    </div>
                </div>

                <div>
                    <div class="card plan-card border-0">
                        <img src="~/images/workout 2.jpg" class="card-img-top rounded-top-3" alt="..." style="height: 250px; object-fit: cover;" />
                        <footer class="card-footer bg-white border-0 text-center py-4">
                            <h5 class="card-title text-uppercase fw-bolder" style="color: var(--clr-primary);">
                                strength training
                            </h5>
                            <a href="#" class="text-decoration-none fw-semibold" style="color: var(--clr-text-muted);">Explore <i class="fa-solid fa-arrow-right ms-1"></i></a>
                        </footer>
                    </div>
                </div>

                <div>
                    <div class="card plan-card border-0">
                        <img src="~/images/workout 3.jpg" class="card-img-top rounded-top-3" alt="..." style="height: 250px; object-fit: cover;" />
                        <footer class="card-footer bg-white border-0 text-center py-4">
                            <h5 class="card-title text-uppercase fw-bolder" style="color: var(--clr-primary);">
                                cardio blast
                            </h5>
                            <a href="#" class="text-decoration-none fw-semibold" style="color: var(--clr-text-muted);">Explore <i class="fa-solid fa-arrow-right ms-1"></i></a>
                        </footer>
                    </div>
                </div>
            </div>

            <div class="indicators d-flex justify-content-center gap-2 mt-5">
                <div class="indicator rounded-circle" style="width:10px; height:10px; background: rgba(255,255,255,0.3);"></div>
                <div class="indicator rounded-pill bg-white" style="width:30px; height:10px;"></div>
                <div class="indicator rounded-circle" style="width:10px; height:10px; background: rgba(255,255,255,0.3);"></div>
                <div class="indicator rounded-circle" style="width:10px; height:10px; background: rgba(255,255,255,0.3);"></div>
            </div>
        </div>
    </section>

    <!-- ^ why-us section -->
    <section class="why-us my-5 py-5">
        <div class="container">
            <div class="row row-cols-1 row-cols-lg-2 align-items-center">
                <div class="info">
                    <div>
                        <div class="title d-flex justify-content-start align-items-center gap-2 mb-3">
                            <i class="fa-solid fa-bolt fs-3 text-primary-custom"></i>
                            <h2 class="text-primary-custom fs-5 m-0 fw-bold text-uppercase">Why Us</h2>
                        </div>

                        <header>
                            <h3 class="fw-bolder display-5 mb-4" style="color: var(--clr-text-dark);">
                                Elevate fitness with<br />
                                <span class="text-primary-custom">the best</span> way
                                possible
                            </h3>
                            <p class="text mb-5" style="color: var(--clr-text-muted); line-height: 1.7;">
                                We believe fitness is more than just a workout—it's a
                                lifestyle. With top-of-the-line facilities, certified
                                trainers, and a supportive community, we're here to inspire
                                and guide you every step of the way.
                            </p>
                        </header>

                        <ul class="features list-unstyled">
                            <li class="feature d-flex gap-4 align-items-start mb-4">
                                <div class="count d-flex align-items-center justify-content-center rounded-circle bg-primary-custom text-white fw-bold shadow" style="width: 60px; height: 60px; flex-shrink: 0;">01</div>
                                <div class="text mt-2">
                                    <h4 class="text-capitalize fw-bold fs-5 mb-2" style="color: var(--clr-text-dark);">
                                        personalized fitness plans
                                    </h4>
                                    <p style="color: var(--clr-text-muted);">
                                        We tailor every workout to fit your unique goals and
                                        fitness level ensuring that you make the most progress.
                                    </p>
                                </div>
                            </li>

                            <li class="feature d-flex gap-4 align-items-start mb-4">
                                <div class="count d-flex align-items-center justify-content-center rounded-circle bg-primary-custom text-white fw-bold shadow" style="width: 60px; height: 60px; flex-shrink: 0;">02</div>
                                <div class="text mt-2">
                                    <h4 class="text-capitalize fw-bold fs-5 mb-2" style="color: var(--clr-text-dark);">
                                        expert guidance
                                    </h4>
                                    <p style="color: var(--clr-text-muted);">
                                        We tailor every workout to fit your unique goals and
                                        fitness level ensuring that you make the most progress.
                                    </p>
                                </div>
                            </li>

                            <li class="feature d-flex gap-4 align-items-start">
                                <div class="count d-flex align-items-center justify-content-center rounded-circle bg-primary-custom text-white fw-bold shadow" style="width: 60px; height: 60px; flex-shrink: 0;">03</div>
                                <div class="text mt-2">
                                    <h4 class="text-capitalize fw-bold fs-5 mb-2" style="color: var(--clr-text-dark);">
                                        modern equipment
                                    </h4>
                                    <p style="color: var(--clr-text-muted);">
                                        We tailor every workout to fit your unique goals and
                                        fitness level ensuring that you make the most progress.
                                    </p>
                                </div>
                            </li>
                        </ul>
                    </div>
                </div>

                <div class="characters d-none d-lg-block text-center">
                    <div class="images">
                        <img class="img-fluid rounded-4 shadow" src="~/images/why us images.jpg" alt="characters" style="max-height: 600px;" />
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

