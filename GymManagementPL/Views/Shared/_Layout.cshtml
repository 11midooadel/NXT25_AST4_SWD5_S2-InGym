@{
    var CurrentCotroller = ViewContext.RouteData.Values["Controller"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- FontAwesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <!-- Professional Typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet" />
    
    <!-- Bootstrap 5.3.8 -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    
    <!-- Main Stylesheet -->
    <link rel="stylesheet" href="~/css/style.css" />
    
    <title>InGym | @ViewData["Title"]</title>
</head>

<body>
    <header class="sticky-top pt-3">
        <nav class="navbar navbar-expand-lg bg-white mx-3 mb-3 shadow-sm">
            <div class="container">
                <!-- FontAwesome Logo & Branding -->
                <a class="navbar-brand d-flex align-items-center gap-2 brand-text" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-dumbbell fs-3"></i>
                    <span class="fs-4 fw-bold">InGym</span>
                </a>
                
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <i class="fa-solid fa-bars fs-4 text-primary-custom"></i>
                </button>

                <div class="collapse navbar-collapse" id="navbarSupportedContent">
                    <ul class="navbar-nav m-auto mb-2 mb-lg-0 mt-3 mt-lg-0">
                        <li class="nav-item">
                            <a class="nav-link px-3 py-2 mx-2 fw-semibold fs-6 @(CurrentCotroller == "Home" ? "active" : "")" aria-current="page"
                                   asp-controller="Home" asp-action="Index">
                                <i class="fa-solid fa-house-chimney me-1"></i> Home
                            </a>
                        </li>
                        @if (User.IsInRole("SuperAdmin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link px-3 py-2 mx-2 fw-semibold fs-6 @(CurrentCotroller == "Member" ? "active" : "")" aria-current="page" asp-controller="Member" asp-action="Index">
                                    <i class="fa-solid fa-users me-1"></i> Members
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link px-3 py-2 mx-2 fw-semibold fs-6 @(CurrentCotroller == "Trainer" ? "active" : "")" aria-current="page" asp-controller="Trainer" asp-action="Index">
                                    <i class="fa-solid fa-user-tie me-1"></i> Trainers
                                </a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link px-3 py-2 mx-2 fw-semibold fs-6 @(CurrentCotroller == "Session" ? "active" : "")" aria-current="page" asp-controller="Session" asp-action="Index">
                                <i class="fa-regular fa-calendar-check me-1"></i> Sessions
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 py-2 mx-2 fw-semibold fs-6 @(CurrentCotroller == "Plan" ? "active" : "")" aria-current="page" asp-controller="Plan" asp-action="Index">
                                <i class="fa-solid fa-clipboard-list me-1"></i> Plans
                            </a>
                        </li>
                        <li class="nav-item">
                            <form asp-action="Logout" asp-controller="Account" method="post" class="d-inline">
                                <button type="submit" class="btn btn-link nav-link px-3 py-2 mx-2 fw-semibold fs-6 text-danger text-decoration-none">
                                    <i class="fa-solid fa-arrow-right-from-bracket me-1"></i> Logout
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3 page-wrapper">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>