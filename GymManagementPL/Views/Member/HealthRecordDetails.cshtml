@model HealthRecordViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-light text-center py-4 border-0">
                    <h3 class="mb-0 fw-bold"><i class="fa-solid fa-file-medical me-2"></i>Health Record</h3>
                </div>

                <div class="card-body p-4 bg-light">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="card border-0 shadow-sm p-4 h-100 rounded-3">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="bg-primary-custom rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                                        <i class="fa-solid fa-ruler-vertical text-white fs-5"></i>
                                    </div>
                                    <h6 class="text-muted fw-bold mb-0 text-uppercase">Height</h6>
                                </div>
                                <h3 class="text-primary-custom fw-bolder mb-0 ms-5 ps-3">@Model.Height <span class="fs-6 text-muted fw-normal">cm</span></h3>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card border-0 shadow-sm p-4 h-100 rounded-3">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="bg-primary-custom rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                                        <i class="fa-solid fa-weight-scale text-white fs-5"></i>
                                    </div>
                                    <h6 class="text-muted fw-bold mb-0 text-uppercase">Weight</h6>
                                </div>
                                <h3 class="text-primary-custom fw-bolder mb-0 ms-5 ps-3">@Model.Weight <span class="fs-6 text-muted fw-normal">kg</span></h3>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card border-0 shadow-sm p-4 h-100 rounded-3">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="bg-danger rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                                        <i class="fa-solid fa-droplet text-white fs-5"></i>
                                    </div>
                                    <h6 class="text-muted fw-bold mb-0 text-uppercase">Blood Type</h6>
                                </div>
                                <h3 class="text-danger fw-bolder mb-0 ms-5 ps-3">@Model.BloodType</h3>
                            </div>
                        </div>
                        
                        <div class="col-md-6">
                            <div class="card border-0 shadow-sm p-4 h-100 rounded-3">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="bg-warning rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                                        <i class="fa-solid fa-notes-medical text-white fs-5"></i>
                                    </div>
                                    <h6 class="text-muted fw-bold mb-0 text-uppercase">Medical Note</h6>
                                </div>
                                <h5 class="text-dark mb-0 ms-5 ps-3 fw-medium">@(Model.Note ?? "No Notes Found")</h5>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 d-flex">
                        <a asp-controller="Member" asp-action="Index" class="btn-fill flex-fill text-center">
                            <i class="fa-solid fa-arrow-left me-2"></i> Back to List
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>