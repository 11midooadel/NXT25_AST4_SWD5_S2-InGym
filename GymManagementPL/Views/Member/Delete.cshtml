<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card p-5 shadow-lg rounded-4 border-0 text-center">
                <i class="fa-solid fa-triangle-exclamation text-danger display-1 mb-4" style="font-weight: 900;"></i>
                <h3 class="fw-bold text-primary-custom mb-3">Delete Member?</h3>

                <div class="alert alert-danger text-start border-0 shadow-sm rounded-3" role="alert">
                    <i class="fa-solid fa-circle-exclamation me-2"></i>
                    <strong>Warning!</strong> This action cannot be undone. All member data and records will be permanently erased.
                </div>

                <form asp-action="DeleteConfirm" method="post" class="mt-4">
                    <input hidden readonly name="id" value="@ViewBag.MemberId" />
                    <div class="d-flex justify-content-between gap-3">
                        <a asp-controller="Member" asp-action="Index" class="btn-outline flex-fill text-center">Cancel</a>
                        <button type="submit" class="btn btn-danger flex-fill fw-bold rounded-3">Yes, Delete</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>