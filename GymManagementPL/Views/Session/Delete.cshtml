<div class="container mt-5 page-wrapper">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card p-5 shadow-lg rounded-4 border-0 text-center">
                <i class="fa-solid fa-triangle-exclamation text-danger display-1 mb-4" style="font-weight: 900;"></i>
                <h3 class="fw-bold text-primary-custom mb-3">Delete Session?</h3>

                <div class="alert alert-danger text-start border-0 shadow-sm rounded-3 mb-4" role="alert">
                    <i class="fa-solid fa-circle-exclamation me-2"></i>
                    <strong>Warning!</strong> This action cannot be undone. All session data and bookings will be permanently deleted.
                </div>
                
                <p class="text-muted mb-4">Are you sure you want to proceed with deleting this session?</p>

                <form asp-action="DeleteConfirmed" method="post">
                    <input type="hidden" name="id" value="@ViewBag.SessionId" />
                    <div class="d-flex justify-content-between gap-3">
                        <a asp-action="Index" class="btn-outline flex-fill text-center">
                            Cancel
                        </a>
                        <button type="submit" class="btn btn-danger flex-fill fw-bold rounded-3 py-2">
                            Yes, Delete
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>