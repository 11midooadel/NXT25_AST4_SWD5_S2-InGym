@model IEnumerable<SessionViewModel>

@{
    ViewData["Title"] = "Sessions";
}

@if (TempData["SuccessMessage"] != null)
{
    <div id="Alert" class="alert alert-success alert-dismissible fade show shadow-sm border-0 mt-3">
        <i class="fa-solid fa-circle-check me-2"></i>
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
else if (TempData["ErrorMessage"] != null)
{
    <div id="Alert" class="alert alert-danger alert-dismissible fade show shadow-sm border-0 mt-3">
        <i class="fa-solid fa-triangle-exclamation me-2"></i>
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container page-wrapper">
    <header class="d-flex justify-content-between mb-4 align-items-center">
        <div>
            <h2 class="text-primary-custom fw-bold mb-0">Training Sessions</h2>
            <p class="text-muted">Manage gym training sessions and classes</p>
        </div>
        <a asp-controller="Session" asp-action="Create" class="btn-fill fw-medium rounded-pill px-4">
            <i class="fa-solid fa-plus me-1"></i> Add Session
        </a>
    </header>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var session in Model)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border rounded-4 overflow-hidden session-card bg-white">
                        <div class="card-header text-white py-3 border-0 @(session.Status == "Ongoing" ? "bg-success" : session.Status == "Upcoming" ? "bg-primary-custom" : "bg-secondary")">
                            <div class="d-flex justify-content-between align-items-center">
                                <h5 class="mb-0 fw-bold text-white">
                                    <i class="fa-regular fa-calendar-check me-2"></i>@session.CategoryName
                                </h5>
                                <span class="badge bg-white text-dark shadow-sm px-3 py-2 rounded-pill">@session.Status</span>
                            </div>
                        </div>
                        <div class="card-body">
                            <p class="text-muted mb-4 small" style="line-height: 1.6;">@session.Description</p>

                            <div class="session-info">
                                <div class="info-item mb-3 d-flex align-items-center gap-3">
                                    <div class="icon-box bg-light rounded-circle text-primary-custom d-flex justify-content-center align-items-center" style="width: 35px; height: 35px;">
                                        <i class="fa-solid fa-user-tie"></i>
                                    </div>
                                    <div>
                                        <small class="text-muted d-block" style="font-size: 0.75rem;">Trainer</small>
                                        <strong class="text-dark">@session.TrainerName</strong>
                                    </div>
                                </div>
                                
                                <div class="info-item mb-3 d-flex align-items-center gap-3">
                                    <div class="icon-box bg-light rounded-circle text-primary-custom d-flex justify-content-center align-items-center" style="width: 35px; height: 35px;">
                                        <i class="fa-regular fa-calendar"></i>
                                    </div>
                                    <div>
                                        <small class="text-muted d-block" style="font-size: 0.75rem;">Date & Time</small>
                                        <strong class="text-dark">@session.DateDisplay • @session.TimeRangeDisplay</strong>
                                    </div>
                                </div>

                                <div class="info-item mb-3 d-flex align-items-center gap-3">
                                    <div class="icon-box bg-light rounded-circle text-primary-custom d-flex justify-content-center align-items-center" style="width: 35px; height: 35px;">
                                        <i class="fa-solid fa-hourglass-half"></i>
                                    </div>
                                    <div>
                                        <small class="text-muted d-block" style="font-size: 0.75rem;">Duration</small>
                                        <strong class="text-dark">@session.Duration</strong>
                                    </div>
                                </div>

                                <div class="info-item d-flex align-items-center gap-3">
                                    <div class="icon-box bg-light rounded-circle text-primary-custom d-flex justify-content-center align-items-center" style="width: 35px; height: 35px;">
                                        <i class="fa-solid fa-users"></i>
                                    </div>
                                    <div>
                                        <small class="text-muted d-block" style="font-size: 0.75rem;">Capacity</small>
                                        <strong class="text-dark">@session.AvailableSlots / @session.Capacity slots available</strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-light border-0 p-3">
                            <div class="d-grid gap-2">
                                <a asp-action="Details" asp-route-id="@session.Id" class="btn-fill btn-sm py-2">
                                    <i class="fa-solid fa-eye me-1"></i> View Details
                                </a>
                                <div class="d-flex gap-2">
                                    <a asp-action="Edit" asp-route-id="@session.Id" class="btn-outline btn-sm flex-fill">
                                        <i class="fa-solid fa-pen-to-square me-1"></i> Edit
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@session.Id" class="btn-outline text-danger border-danger btn-sm flex-fill" onmouseover="this.style.backgroundColor='#dc3545'; this.style.color='#fff';" onmouseout="this.style.backgroundColor='transparent'; this.style.color='#dc3545';">
                                        <i class="fa-solid fa-trash-can me-1"></i> Delete
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm border">
            <i class="fa-regular fa-calendar-xmark display-1 text-muted opacity-50" style="font-weight: 900;"></i>
            <h4 class="mt-4 text-dark fw-bold">No Sessions Available</h4>
            <p class="text-muted">Create your first training session to get started</p>
        </div>
    }
</div>

@section Scripts {
    <partial name="_AlertBoxScript" />
}