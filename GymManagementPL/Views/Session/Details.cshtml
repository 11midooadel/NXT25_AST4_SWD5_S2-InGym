@model SessionViewModel

<div class="container mt-5 page-wrapper">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header text-white text-center py-5 border-0 @(Model.Status == "Ongoing" ? "bg-success" : Model.Status == "Upcoming" ? "bg-primary-custom" : "bg-secondary")">
                    <i class="fa-regular fa-calendar-check display-4 mb-3"></i>
                    <h2 class="mb-2 fw-bold text-white">@Model.CategoryName</h2>
                    <span class="badge bg-white text-dark fs-6 px-3 py-2 rounded-pill shadow-sm">@Model.Status</span>
                </div>

                <div class="card-body p-4 bg-light">
                    <!-- Description -->
                    <div class="mb-4 p-4 bg-white rounded-4 shadow-sm border-0">
                        <h6 class="text-primary-custom mb-3 fw-bold text-uppercase small">
                            <i class="fa-solid fa-align-left me-2"></i>Description
                        </h6>
                        <p class="mb-0 text-dark" style="line-height: 1.7;">@Model.Description</p>
                    </div>

                    <!-- Session Details -->
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="p-3 bg-white rounded-3 shadow-sm border-0 d-flex align-items-center h-100">
                                <div class="icon-box me-3 bg-primary-subtle text-primary-custom rounded-circle d-flex justify-content-center align-items-center" style="width: 45px; height: 45px;">
                                    <i class="fa-solid fa-user-tie fs-5"></i>
                                </div>
                                <div>
                                    <small class="text-muted d-block" style="font-size: 0.75rem;">Trainer</small>
                                    <strong class="text-dark">@Model.TrainerName</strong>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-white rounded-3 shadow-sm border-0 d-flex align-items-center h-100">
                                <div class="icon-box me-3 bg-primary-subtle text-primary-custom rounded-circle d-flex justify-content-center align-items-center" style="width: 45px; height: 45px;">
                                    <i class="fa-solid fa-users fs-5"></i>
                                </div>
                                <div>
                                    <small class="text-muted d-block" style="font-size: 0.75rem;">Capacity</small>
                                    <strong class="text-dark">@Model.AvailableSlots / @Model.Capacity spots</strong>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-white rounded-3 shadow-sm border-0 d-flex align-items-center h-100">
                                <div class="icon-box me-3 bg-primary-subtle text-primary-custom rounded-circle d-flex justify-content-center align-items-center" style="width: 45px; height: 45px;">
                                    <i class="fa-regular fa-clock fs-5"></i>
                                </div>
                                <div>
                                    <small class="text-muted d-block" style="font-size: 0.75rem;">Start Time</small>
                                    <strong class="text-dark">@Model.StartDate</strong>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-white rounded-3 shadow-sm border-0 d-flex align-items-center h-100">
                                <div class="icon-box me-3 bg-primary-subtle text-primary-custom rounded-circle d-flex justify-content-center align-items-center" style="width: 45px; height: 45px;">
                                    <i class="fa-solid fa-flag-checkered fs-5"></i>
                                </div>
                                <div>
                                    <small class="text-muted d-block" style="font-size: 0.75rem;">End Time</small>
                                    <strong class="text-dark">@Model.EndDate</strong>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="p-4 bg-primary-custom rounded-4 shadow-sm border-0 d-flex align-items-center justify-content-center text-white mt-2">
                                <i class="fa-solid fa-hourglass-half fs-3 me-3 opacity-75"></i>
                                <div>
                                    <small class="d-block opacity-75 text-uppercase" style="font-size: 0.75rem;">Total Duration</small>
                                    <strong class="fs-5">@Model.Duration.Hours Hours @Model.Duration.Minutes Minutes</strong>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-white border-0 p-4">
                    <div class="d-flex justify-content-between gap-2">
                        <a asp-action="Index" class="btn-outline flex-fill text-center py-2">
                            <i class="fa-solid fa-arrow-left me-2"></i> Back to List
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>