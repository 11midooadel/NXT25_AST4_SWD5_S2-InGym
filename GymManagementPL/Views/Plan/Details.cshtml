@model PlanViewModel

<div class="container mt-5 page-wrapper">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <!-- bg-primary-custom if plan is Active, bg-secondary if Inactive -->
                <div class="card-header text-white text-center py-5 border-0 @(Model.IsActive ? "bg-primary-custom" : "bg-secondary")">
                    <i class="fa-solid fa-medal display-4 mb-3" style="font-weight: 900;"></i>
                    <h2 class="mb-0 fw-bold text-white">@Model.Name</h2>
                </div>
                
                <div class="card-body p-4 bg-light">
                    <div class="text-center mb-5 py-4 bg-white rounded-4 shadow-sm border-0">
                        <div class="display-3 fw-bold text-primary-custom">@Model.Price.ToString("N0")</div>
                        <small class="text-muted fs-5 fw-semibold">EGP</small>
                    </div>

                    <div class="plan-details row g-4">
                        <div class="col-12 col-md-6">
                            <div class="p-3 bg-white rounded-3 shadow-sm border-0 d-flex align-items-center h-100">
                                <div class="icon-box me-3 bg-primary-subtle text-primary-custom rounded-circle d-flex justify-content-center align-items-center" style="width: 45px; height: 45px;">
                                    <i class="fa-regular fa-calendar-check fs-5"></i>
                                </div>
                                <div>
                                    <h6 class="mb-0 text-muted small">Duration</h6>
                                    <p class="mb-0 fw-bold text-dark">@Model.DurationDays days</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="p-3 bg-white rounded-3 shadow-sm border-0 d-flex align-items-center h-100">
                                <div class="icon-box me-3 rounded-circle d-flex justify-content-center align-items-center @(Model.IsActive ? "bg-success text-white" : "bg-danger text-white")" style="width: 45px; height: 45px;">
                                    <i class="fa-solid @(Model.IsActive ? "fa-check" : "fa-xmark") fs-5"></i>
                                </div>
                                <div>
                                    <h6 class="mb-1 text-muted small">Status</h6>
                                    <p class="mb-0">
                                        @if (Model.IsActive)
                                        {
                                            <span class="badge bg-success px-3 py-2 rounded-pill shadow-sm">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger px-3 py-2 rounded-pill shadow-sm">Inactive</span>
                                        }
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="p-4 bg-white rounded-3 shadow-sm border-0 d-flex align-items-start h-100">
                                <div class="icon-box me-3 bg-primary-subtle text-primary-custom rounded-circle d-flex justify-content-center align-items-center flex-shrink-0" style="width: 45px; height: 45px;">
                                    <i class="fa-solid fa-align-left fs-5"></i>
                                </div>
                                <div>
                                    <h6 class="mb-2 text-primary-custom fw-bold text-uppercase small">Description</h6>
                                    <p class="mb-0 text-muted" style="line-height: 1.7;">@Model.Description</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-white border-0 p-4">
                    <div class="d-flex justify-content-between gap-2">
                        <a asp-action="Index" class="btn-outline flex-fill text-center py-2">
                            <i class="fa-solid fa-arrow-left me-2"></i> Back to Plans
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>