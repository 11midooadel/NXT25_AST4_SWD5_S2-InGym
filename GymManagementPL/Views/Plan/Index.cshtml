@model IEnumerable<PlanViewModel>

@{
    ViewData["Title"] = "Plans";
}

@if (TempData["SuccessMessage"] is not null)
{
    <div id="Alert" class="alert alert-success alert-dismissible fade show shadow-sm border-0 mt-3">
        <i class="fa-solid fa-circle-check me-2"></i>
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] is not null)
{
    <div id="Alert" class="alert alert-danger alert-dismissible fade show shadow-sm border-0 mt-3">
        <i class="fa-solid fa-triangle-exclamation me-2"></i>
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container page-wrapper">
    <header class="d-flex justify-content-between mb-4 align-items-center">
        <div>
            <h2 class="text-primary-custom fw-bold mb-0">Membership Plans</h2>
            <p class="text-muted">Manage your gym membership packages</p>
        </div>
    </header>

    @if (Model is not null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var plan in Model)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border rounded-4 plan-card bg-white overflow-hidden">
                        <!-- bg-primary-custom if plan is Active  bg-secondary is Inactive-->
                        <div class="card-header text-white text-center py-4 border-0 @(plan.IsActive ? "bg-primary-custom" : "bg-secondary")">
                            <h4 class="mb-0 fw-bold text-white">@plan.Name</h4>
                        </div>
                        <div class="card-body d-flex flex-column p-4">
                            <div class="text-center mb-4 pb-3 border-bottom">
                                <div class="display-4 fw-bold text-primary-custom">@plan.Price.ToString("N0")</div>
                                <small class="text-muted fw-semibold">EGP</small>
                            </div>

                            <div class="mb-4 flex-grow-1">
                                <p class="text-dark mb-3 d-flex align-items-center gap-2">
                                    <i class="fa-regular fa-calendar-check text-primary-custom fs-5"></i>
                                    <strong>Duration:</strong> <span class="text-muted">@plan.DurationDays Days</span>
                                </p>
                                <p class="text-dark mb-2 d-flex align-items-center gap-2">
                                    <i class="fa-solid fa-align-left text-primary-custom fs-5"></i>
                                    <strong>Description:</strong>
                                </p>
                                <p class="small text-muted" style="line-height: 1.6;">@plan.Description</p>
                            </div>

                            <div class="mt-auto">
                                <div class="d-grid gap-2">
                                    <a asp-action="Details" asp-route-id="@plan.Id" class="btn-fill btn-sm py-2">
                                        <i class="fa-solid fa-eye me-1"></i> View Details
                                    </a>
                                    <div class="d-flex gap-2">
                                        <a asp-action="Edit" asp-route-id="@plan.Id" class="btn-outline btn-sm flex-fill d-flex align-items-center justify-content-center">
                                            <i class="fa-solid fa-pen-to-square me-1"></i> Edit
                                        </a>
                                        <form asp-action="Activate" asp-route-id="@plan.Id" method="post" class="flex-fill d-flex">
                                            @if (plan.IsActive)
                                            {
                                                <button type="submit" class="btn-outline btn-sm w-100 text-danger border-danger" onmouseover="this.style.backgroundColor='#dc3545'; this.style.color='#fff';" onmouseout="this.style.backgroundColor='transparent'; this.style.color='#dc3545';">
                                                    <i class="fa-solid fa-ban me-1"></i> Deactivate
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="btn-outline btn-sm w-100 text-success border-success" onmouseover="this.style.backgroundColor='#198754'; this.style.color='#fff';" onmouseout="this.style.backgroundColor='transparent'; this.style.color='#198754';">
                                                    <i class="fa-regular fa-circle-check me-1"></i> Activate
                                                </button>
                                            }
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm border">
            <i class="fa-solid fa-box-open display-1 text-muted opacity-50" style="font-weight: 900;"></i>
            <h4 class="mt-4 text-dark fw-bold">No Plans Available</h4>
            <p class="text-muted">Create your first membership plan to get started</p>
        </div>
    }
</div>

@section Scripts {
    <partial name="_AlertBoxScript" />
}