@model UpdatePlanViewModel

<div class="container mt-4 page-wrapper">
    <header class="mb-4">
        <h3 class="text-primary-custom fw-bold"><i class="fa-solid fa-pen-to-square me-2"></i>Edit Plan</h3>
        <p class="text-muted">Update plan details and pricing</p>
    </header>

    @Html.ValidationMessage("WrongData", new { @class = "text-danger" })

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border rounded-4 bg-white p-4">
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <div class="row g-4">
                            <div class="col-12">
                                <label asp-for="PlanName" class="form-label fw-semibold text-muted small">
                                    Plan Name <span class="text-danger">*</span>
                                </label>
                                <input asp-for="PlanName" class="form-control bg-light" readonly />
                            </div>

                            <div class="col-md-6">
                                <label asp-for="DurationDays" class="form-label fw-semibold text-muted small">
                                    Duration (Days) <span class="text-danger">*</span>
                                </label>
                                <div class="input-group">
                                    <input asp-for="DurationDays" type="number" class="form-control bg-light" />
                                    <span class="input-group-text bg-white text-muted">Days</span>
                                </div>
                                <small class="text-muted d-block mt-1">e.g., 30 days = 1 month</small>
                                <span asp-validation-for="DurationDays" class="text-danger small d-block"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Price" class="form-label fw-semibold text-muted small">
                                    Price (EGP) <span class="text-danger">*</span>
                                </label>
                                <div class="input-group">
                                    <input asp-for="Price" type="number" step="0.01" class="form-control bg-light" />
                                    <span class="input-group-text bg-white text-muted">EGP</span>
                                </div>
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Description" class="form-label fw-semibold text-muted small">
                                    Description <span class="text-danger">*</span>
                                </label>
                                <textarea asp-for="Description" class="form-control bg-light" rows="4"></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-5 pt-3 border-top gap-3">
                            <a asp-action="Index" class="btn-outline px-4 text-center">
                                Cancel
                            </a>
                            <button type="submit" class="btn-fill px-4">
                                <i class="fa-solid fa-floppy-disk me-2"></i> Update Plan
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}