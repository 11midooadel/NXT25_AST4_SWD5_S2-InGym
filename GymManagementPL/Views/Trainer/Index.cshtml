@model IEnumerable<TrainerViewModel>

@{
    ViewData["Title"] = "Trainers";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@if (TempData["SuccessMessage"] != null)
{
    <div id="Alert" class="alert alert-success alert-dismissible fade show shadow-sm border-0 mt-3">
        <i class="fa-solid fa-circle-check me-2"></i>
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
else if (TempData["ErrorMessage"] != null)
{
    <div id="Alert" class="alert alert-danger alert-dismissible fade show shadow-sm border-0 mt-3">
        <i class="fa-solid fa-triangle-exclamation me-2"></i>
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container page-wrapper">
    <header class="d-flex justify-content-between mb-4 align-items-center">
        <div>
            <h2 class="text-primary-custom fw-bold mb-0">Our Trainers</h2>
            <p class="text-muted">Professional fitness instructors</p>
        </div>
        <a asp-controller="Trainer" asp-action="Create" class="btn-fill fw-medium rounded-pill px-4">
            <i class="fa-solid fa-plus me-1"></i> Add Trainer
        </a>
    </header>

    @if (Model != null && Model.Any())
    {
        <div class="table-wrapper">
            <table class="table table-borderless mb-0">
                <thead>
                    <tr>
                        <th><span>Name</span></th>
                        <th><span>Email</span></th>
                        <th><span>Phone</span></th>
                        <th><span>Specialization</span></th>
                        <th class="text-center"><span>Action</span></th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var trainer in Model)
                    {
                        <tr>
                            <td class="fw-bold text-dark"><span>@trainer.Name</span></td>
                            <td class="text-muted"><span>@trainer.Email</span></td>
                            <td class="text-muted"><span>@trainer.Phone</span></td>
                            <td>
                                <span class="badge bg-primary-custom fw-medium px-3 py-2 rounded-pill">@trainer.Specialties</span>
                            </td>
                            <td class="action text-center">
                                <div class="dropdown">
                                    <button class="btn btn-link p-2 border-0 text-muted" type="button"
                                            id="dropdownMenuButton-@trainer.Id" data-bs-toggle="dropdown"
                                            aria-expanded="false">
                                        <i class="fa-solid fa-ellipsis-vertical fs-5"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0"
                                        aria-labelledby="dropdownMenuButton-@trainer.Id">
                                        <li>
                                            <a asp-controller="Trainer" asp-action="Details" asp-route-id="@trainer.Id"
                                                   class="dropdown-item d-flex align-items-center gap-3 py-2">
                                                <i class="fa-solid fa-address-card text-primary-custom" style="width: 20px;"></i>
                                                <span>View Details</span>
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <a asp-controller="Trainer" asp-action="Edit" asp-route-id="@trainer.Id"
                                                   class="dropdown-item d-flex align-items-center gap-3 py-2">
                                                <i class="fa-solid fa-pen-to-square text-warning" style="width: 20px;"></i>
                                                <span>Edit Details</span>
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <a asp-controller="Trainer" asp-action="Delete" asp-route-id="@trainer.Id"
                                                   class="dropdown-item d-flex align-items-center gap-3 py-2 text-danger">
                                                <i class="fa-solid fa-trash-can" style="width: 20px;"></i>
                                                <span>Delete</span>
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm border">
            <i class="fa-solid fa-people-line display-1 text-muted opacity-50" style="font-weight: 900;"></i>
            <h4 class="mt-4 text-dark fw-bold">No Trainers Available</h4>
            <p class="text-muted">Add your first trainer to get started</p>
        </div>
    }
</div>

@section Scripts {
    <partial name="_AlertBoxScript" />
}