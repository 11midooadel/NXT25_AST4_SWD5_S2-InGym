@model CreateTrainerViewModel

@{
    ViewData["Title"] = "Add New Trainer";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container page-wrapper">
    <header class="mb-4">
        <h3 class="text-primary-custom fw-bold"><i class="fa-solid fa-user-plus me-2"></i>Add New Trainer</h3>
    </header>
    
    @Html.ValidationMessage("DataMissed", new { @class = "text-danger" })
    
    <form method="post" asp-action="CreateTrainer" class="bg-white p-4 rounded-4 shadow-sm border">

        <!-- Personal Information -->
        <div class="section-header mb-4">
            <h5 class="text-primary-custom fw-bold m-0">Personal Information</h5>
            <hr class="mt-2 text-muted">
        </div>
        <div class="row g-4">
            <div class="col-12 col-md-6">
                <label asp-for="Name" class="form-label fw-medium"></label>
                <input asp-for="Name" type="text" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="col-12 col-md-6">
                <label asp-for="Email" class="form-label fw-medium"></label>
                <input asp-for="Email" type="text" class="form-control" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="col-12 col-md-6">
                <label asp-for="Phone" class="form-label fw-medium"></label>
                <input asp-for="Phone" type="text" class="form-control" />
                <span asp-validation-for="Phone" class="text-danger small"></span>
            </div>

            <div class="col-12 col-md-6">
                <label asp-for="DateOfBirth" class="form-label fw-medium"></label>
                <input asp-for="DateOfBirth" type="date" class="form-control" />
                <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
            </div>

            <div class="col-12 col-md-6">
                <label asp-for="Gender" class="form-label fw-medium"></label>
                <select asp-for="Gender" asp-items="Html.GetEnumSelectList<Gender>()" class="form-select">
                    <option value="">-- Select Gender --</option>
                </select>
                <span asp-validation-for="Gender" class="text-danger small"></span>
            </div>
        </div>

        <!-- Address Information -->
        <div class="section-header mb-4 mt-5">
            <h5 class="text-primary-custom fw-bold m-0">Address Information</h5>
            <hr class="mt-2 text-muted">
        </div>
        <div class="row g-4">
            <div class="col-12 col-md-4">
                <label asp-for="BuildingNumber" class="form-label fw-medium"></label>
                <input asp-for="BuildingNumber" type="text" class="form-control" />
                <span asp-validation-for="BuildingNumber" class="text-danger small"></span>
            </div>

            <div class="col-12 col-md-4">
                <label asp-for="Street" class="form-label fw-medium">Street</label>
                <input asp-for="Street" type="text" class="form-control" />
                <span asp-validation-for="Street" class="text-danger small"></span>
            </div>
            
            <div class="col-12 col-md-4">
                <label asp-for="City" class="form-label fw-medium">City</label>
                <input asp-for="City" type="text" class="form-control" />
                <span asp-validation-for="City" class="text-danger small"></span>
            </div>
        </div>

        <!-- Professional Information -->
        <div class="section-header mb-4 mt-5">
            <h5 class="text-primary-custom fw-bold m-0">Professional Information</h5>
            <hr class="mt-2 text-muted">
        </div>
        <div class="row g-4">
            <div class="col-12 col-md-6">
                <label asp-for="Specialties" class="form-label fw-medium"></label>
                <select asp-for="Specialties" asp-items="Html.GetEnumSelectList<Specialties>()" class="form-select">
                    <option value="">-- Select Specialization --</option>
                </select>
                <span asp-validation-for="Specialties" class="text-danger small"></span>
            </div>
        </div>

        <footer class="d-flex justify-content-end mt-5 pt-3 border-top gap-3">
            <a asp-action="Index" class="btn-outline px-4">Cancel</a>
            <button type="submit" class="btn-fill px-4"><i class="fa-solid fa-floppy-disk me-2"></i> Save Trainer</button>
        </footer>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}