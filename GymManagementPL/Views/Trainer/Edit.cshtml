@model UpdateTrainerViewModel
@{
    ViewData["Title"] = "EditTrainer";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4 page-wrapper">
    <header class="mb-4">
        <h3 class="text-primary-custom fw-bold">Edit Trainer</h3>
        <p class="text-muted">Update professional information</p>
    </header>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border rounded-4">
                <div class="card-body p-5">
                    <div class="mb-4 pb-3 border-bottom">
                        <small class="text-muted d-block mb-1">Editing Profile For</small>
                        <h4 class="mb-0 text-primary-custom fw-bold">@Model.Name</h4>
                    </div>
                    
                    <form asp-action="Edit" method="post">
                        <input asp-for="Name" hidden />
                        <input asp-for="Email" hidden />
                        
                        <!-- Personal Information -->
                        <div class="section-header mb-4">
                            <h5 class="text-primary-custom fw-bold m-0">Contact & Address</h5>
                            <hr class="mt-2 text-muted">
                        </div>
                        <div class="row g-4 mb-5">
                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label fw-medium text-muted small"><i class="fa-solid fa-envelope me-1"></i> Email</label>
                                <input asp-for="Email" type="text" class="form-control bg-light" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Phone" class="form-label fw-medium text-muted small"><i class="fa-solid fa-phone me-1"></i> Phone</label>
                                <input asp-for="Phone" type="text" class="form-control bg-light" />
                                <span asp-validation-for="Phone" class="text-danger small"></span>
                            </div>
                            
                            <div class="col-md-4">
                                <label asp-for="BuildingNumber" class="form-label fw-medium text-muted small"><i class="fa-solid fa-building me-1"></i> Bldg No.</label>
                                <input asp-for="BuildingNumber" type="text" class="form-control bg-light" />
                                <span asp-validation-for="BuildingNumber" class="text-danger small"></span>
                            </div>
                            
                            <div class="col-md-8">
                                <label asp-for="Street" class="form-label fw-medium text-muted small"><i class="fa-solid fa-road me-1"></i> Street</label>
                                <input asp-for="Street" type="text" class="form-control bg-light" />
                                <span asp-validation-for="Street" class="text-danger small"></span>
                            </div>
                            
                            <div class="col-md-12">
                                <label asp-for="City" class="form-label fw-medium text-muted small"><i class="fa-solid fa-city me-1"></i> City</label>
                                <input asp-for="City" type="text" class="form-control bg-light" />
                                <span asp-validation-for="City" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- Professional Information -->
                        <div class="section-header mb-4">
                            <h5 class="text-primary-custom fw-bold m-0">Professional Information</h5>
                            <hr class="mt-2 text-muted">
                        </div>
                        <div class="row g-4">
                            <div class="col-12 col-md-6">
                                <label asp-for="Specialties" class="form-label fw-medium text-muted small"><i class="fa-solid fa-medal me-1"></i> Specialization</label>
                                <select asp-for="Specialties" asp-items="Html.GetEnumSelectList<Specialties>()" class="form-select bg-light">
                                    <option value="">-- Select Specialization --</option>
                                </select>
                                <span asp-validation-for="Specialties" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between gap-3 mt-5 pt-3 border-top">
                            <a asp-action="Index" class="btn-outline flex-fill text-center">
                                Cancel
                            </a>
                            <button type="submit" class="btn-fill flex-fill">
                                <i class="fa-solid fa-floppy-disk me-2"></i> Update Trainer
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}